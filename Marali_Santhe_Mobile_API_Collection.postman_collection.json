{
  "info": {
    "name": "Marali Santhe - Mobile API",
    "_postman_id": "marali-santhe-mobile-api-v2",
    "description": "Complete mobile API collection for Marali Santhe ecommerce app.\n\n** SETUP INSTRUCTIONS **\n1. Import this collection into Postman\n2. The base_url is already set to https://maralisanthe.com\n3. Run folder '1. Auth' → 'Login' — the token is auto-saved\n4. All authenticated requests use {{token}} automatically\n5. booking_id and product_id are auto-saved from responses\n\n** PAYMENT TEST ORDER **\n1. Login\n2. Place Order - Cashfree\n3. Check Payment Status (should be pending)\n4. Verify Payment (after SDK payment)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",   "value": "https://maralisanthe.com", "type": "string" },
    { "key": "token",      "value": "", "type": "string" },
    { "key": "booking_id", "value": "", "type": "string" },
    { "key": "product_id", "value": "42", "type": "string" }
  ],
  "item": [

    {
      "name": "1. Auth",
      "item": [

        {
          "name": "Register Customer",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200 or 201', function () {",
                "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                "});",
                "const res = pm.response.json();",
                "pm.test('Registration success', function () { pm.expect(res.success).to.be.true; });",
                "if (res.data) console.log('customer_id:', res.data.customer_id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api","v1","mobile","auth","register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"Customer\",\n  \"email\": \"testcustomer@example.com\",\n  \"mobile\": \"9876543210\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}"
            }
          }
        },

        {
          "name": "Login  ← auto-saves token",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const res = pm.response.json();",
                "pm.test('Login success', function () { pm.expect(res.success).to.be.true; });",
                "if (res.data && res.data.token) {",
                "  pm.collectionVariables.set('token', res.data.token);",
                "  console.log('✅ Token saved');",
                "  console.log('customer_id:', res.data.customer_id);",
                "  console.log('username:', res.data.username);",
                "} else {",
                "  console.log('❌ No token — check credentials');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api","v1","mobile","auth","login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testcustomer@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "2. Products  (No Auth Needed)",
      "item": [

        {
          "name": "Get All Products",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const res = pm.response.json();",
                "pm.test('Has products', function () { pm.expect(res.data.products).to.be.an('array'); });",
                "const inStock = res.data.products.find(p => p.is_in_stock);",
                "if (inStock) {",
                "  pm.collectionVariables.set('product_id', inStock.id.toString());",
                "  console.log('✅ product_id set to:', inStock.id, '-', inStock.name, '| Price: ₹' + inStock.selling_price);",
                "}",
                "console.log('Total products on page:', res.data.products.length);",
                "console.log('Total products in DB:', res.data.pagination.total_count);"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/ecommerce/products?page=1&per_page=10",
              "host": ["{{base_url}}"],
              "path": ["api","v1","mobile","ecommerce","products"],
              "query": [
