    {
      "name": "4. Checkout & Payment  ← MAIN FLOW",
      "item": [

        {
          "name": "Step 1 — Place Order COD",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const res = pm.response.json();",
                "pm.test('Order placed', function () { pm.expect(res.success).to.be.true; });",
                "pm.test('payment_method is cod', function () { pm.expect(res.payment_method).to.eql('cod'); });",
                "if (res.booking_id) {",
                "  pm.collectionVariables.set('booking_id', res.booking_id.toString());",
                "  console.log('✅ COD Order created!');",
                "  console.log('   booking_number:', res.booking_number);",
                "  console.log('   booking_id:', res.booking_id, '← saved to {{booking_id}}');",
                "  console.log('   total_amount: ₹' + res.total_amount);",
                "  console.log('   message:', res.message);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/ecommerce/checkout/cart_order",
              "host": ["{{base_url}}"],
              "path": ["api","v1","mobile","ecommerce","checkout","cart_order"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cart_data\": [\n    {\n      \"id\": 42,\n      \"name\": \"COCONUT OIL [1LTR]\",\n      \"price\": 650,\n      \"quantity\": 1\n    },\n    {\n      \"id\": 46,\n      \"name\": \"RAJMUDI RICE [1KG]\",\n      \"price\": 130,\n      \"quantity\": 2\n    }\n  ],\n  \"customer_name\": \"Test Customer\",\n  \"customer_email\": \"testcustomer@example.com\",\n  \"customer_phone\": \"9876543210\",\n  \"delivery_address\": \"123 Main Street, MG Road, Bangalore - 560001\",\n  \"payment_method\": \"cod\"\n}"
            }
          }
        },

        {
          "name": "Step 1 — Place Order Cashfree (Online)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const res = pm.response.json();",
                "pm.test('Cashfree order created', function () { pm.expect(res.success).to.be.true; });",
                "pm.test('Has payment_session_id', function () { pm.expect(res.payment_session_id).to.be.a('string'); });",
                "pm.test('redirect_to_payment is true', function () { pm.expect(res.redirect_to_payment).to.be.true; });",
                "if (res.booking_id) {",
                "  pm.collectionVariables.set('booking_id', res.booking_id.toString());",
                "  console.log('✅ Cashfree Order created!');",
                "  console.log('   booking_number:', res.booking_number);",
                "  console.log('   booking_id:', res.booking_id, '← saved to {{booking_id}}');",
                "  console.log('   cashfree_order_id:', res.cashfree_order_id);",
                "  console.log('   payment_session_id:', res.payment_session_id);",
                "  console.log('   total_amount: ₹' + res.total_amount);",
                "  console.log('');",
                "  console.log('📱 React Native next step:');",
                "  console.log('   CashfreePGApiClient.checkout({ paymentSessionId: \"' + res.payment_session_id + '\", environment: \"PRODUCTION\" })');",
                "  console.log('');",
                "  console.log('📋 After SDK payment, run: Step 3 — Verify Payment');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/ecommerce/checkout/cart_order",
              "host": ["{{base_url}}"],
              "path": ["api","v1","mobile","ecommerce","checkout","cart_order"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cart_data\": [\n    {\n      \"id\": 54,\n      \"name\": \"DESI COW GHEE [500ML]\",\n      \"price\": 600,\n      \"quantity\": 1\n    }\n  ],\n  \"customer_name\": \"Test Customer\",\n  \"customer_email\": \"testcustomer@example.com\",\n  \"customer_phone\": \"9876543210\",\n  \"delivery_address\": \"123 Main Street, MG Road, Bangalore - 560001\",\n  \"payment_method\": \"cashfree\"\n}"
            }
          }
        },

        {
          "name": "Step 2 — Check Payment Status (Poll this)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const res = pm.response.json();",
                "console.log('─────────────────────────────────');",
                "console.log('Booking ID   :', res.data.booking_id);",
                "console.log('Booking No   :', res.data.booking_number);",
                "console.log('Order Status :', res.data.status);",
                "console.log('Payment      :', res.data.payment_status, '| Method:', res.data.payment_method);",
                "console.log('Is Paid      :', res.data.is_paid);",
                "console.log('Is Pending   :', res.data.is_pending);",
                "console.log('Amount       : ₹' + res.data.total_amount);",
                "console.log('Cashfree ID  :', res.data.cashfree_order_id || 'N/A');",
                "console.log('Payment ID   :', res.data.cashfree_payment_id || 'N/A (not yet paid)');",
                "console.log('─────────────────────────────────');",
                "if (res.data.is_paid) {",
                "  console.log('✅ PAID — Order is confirmed!');",
                "} else if (res.data.is_pending) {",
                "  console.log('⏳ PENDING — Customer has not paid yet. Poll again.');",
                "} else {",
                "  console.log('❌ NOT PAID / failed');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/ecommerce/bookings/{{booking_id}}/payment_status",
              "host": ["{{base_url}}"],
              "path": ["api","v1","mobile","ecommerce","bookings","{{booking_id}}","payment_status"]
            }
          }
        },

        {
          "name": "Step 3 — Verify Payment (after Cashfree SDK returns)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                "const res = pm.response.json();",
                "console.log('─────────────────────────────────');",
                "console.log('Verification Result:', res.success ? '✅ PAID' : '❌ NOT PAID');",
                "console.log('Booking:', res.data.booking_number, '| Status:', res.data.status);",
                "console.log('Payment Status:', res.data.payment_status);",
                "console.log('Is Paid:', res.data.is_paid);",
                "if (res.data.payment_completed_at) {",
                "  console.log('Paid at:', res.data.payment_completed_at);",
                "}",
                "console.log('─────────────────────────────────');"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/ecommerce/verify_payment",
              "host": ["{{base_url}}"],
              "path": ["api","v1","mobile","ecommerce","verify_payment"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": {{booking_id}}\n}"
            }
          }
        }

      ]
    },

