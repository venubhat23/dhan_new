<style>
.st-card { cursor:pointer; border:2px solid transparent; transition:all 0.18s; border-radius:10px; }
.st-card:hover { border-color:#1C7C54; box-shadow:0 4px 16px rgba(28,124,84,0.12); transform:translateY(-2px); }
.st-card.selected { border-color:#1C7C54; background:#f0fdf4; }
.st-cart-row { background:#f8fafc; border-radius:8px; padding:0.6rem 0.8rem; margin-bottom:0.4rem; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h5 class="fw-bold mb-1"><i class="bi bi-arrow-left-right me-2" style="color:#1C7C54;"></i>Request Stock Transfer</h5>
    <small class="text-muted">Select products and submit a transfer request for <%= @current_store.name %></small>
  </div>
  <%= link_to store_admin_stock_transfers_path, class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Back
  <% end %>
</div>

<%# Search & Filters %>
<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2">
    <div class="row g-2 align-items-center">
      <div class="col-md-5">
        <input type="text" class="form-control form-control-sm" placeholder="Search products by name or SKU..." id="stSearch" oninput="stFilter()">
      </div>
      <div class="col-md-3">
        <select class="form-select form-select-sm" id="stCatFilter" onchange="stFilter()">
          <option value="">All Categories</option>
          <% @products.map(&:category).compact.uniq.each do |cat| %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% end %>
        </select>
      </div>
      <div class="col-auto d-flex gap-2 align-items-center">
        <small class="text-muted">Filter:</small>
        <div class="btn-group btn-group-sm">
          <button type="button" class="btn btn-outline-primary active" id="stAllBtn" onclick="stStockFilter('all')">All</button>
          <button type="button" class="btn btn-outline-primary" id="stInStockBtn" onclick="stStockFilter('instock')">In Stock</button>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Product Grid %>
<div class="card border-0 shadow-sm" style="margin-bottom:220px;">
  <div class="card-body pt-3">
    <% if @products.any? %>
      <div class="row g-3" id="stGrid">
        <% @products.each do |product| %>
          <% stock = product.cached_total_batch_stock %>
          <div class="col-md-4 col-lg-3 st-item"
               data-id="<%= product.id %>"
               data-name="<%= product.name.downcase %>"
               data-sku="<%= product.sku.to_s.downcase %>"
               data-category="<%= product.category_id %>"
               data-stock="<%= stock %>">
            <div class="card h-100 st-card" id="st-card-<%= product.id %>"
                 onclick="stToggle(<%= product.id %>, '<%= j(product.name) %>', '<%= j(product.sku) %>', <%= stock %>)">

              <div class="position-relative">
                <% if product.images_attached? && product.images.any? %>
                  <%= image_tag product.images.first, class: "card-img-top", style: "height:160px;object-fit:cover;border-radius:8px 8px 0 0;" %>
                <% else %>
                  <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:160px;border-radius:8px 8px 0 0;">
                    <i class="bi bi-box-seam fs-1 text-muted"></i>
                  </div>
                <% end %>

                <% if stock <= 0 %>
                  <span class="position-absolute top-0 end-0 badge bg-danger m-2"><i class="bi bi-x-circle me-1"></i>Out of Stock</span>
                <% elsif stock <= 5 %>
                  <span class="position-absolute top-0 end-0 badge bg-warning text-dark m-2"><i class="bi bi-exclamation-triangle me-1"></i>Low (<%= stock.to_i %>)</span>
                <% else %>
                  <span class="position-absolute top-0 end-0 badge bg-success m-2"><i class="bi bi-check-circle me-1"></i><%= stock.to_i %> in stock</span>
                <% end %>

                <div class="position-absolute top-0 start-0 m-2 d-none" id="st-check-<%= product.id %>">
                  <span class="badge rounded-circle p-2" style="background:#1C7C54;"><i class="bi bi-check-lg text-white"></i></span>
                </div>
              </div>

              <div class="card-body d-flex flex-column p-3">
                <small class="text-muted mb-1"><%= product.category&.name || 'No Category' %></small>
                <h6 class="fw-semibold mb-1" style="font-size:0.88rem;min-height:36px;"><%= product.name %></h6>
                <small class="text-muted mb-2">SKU: <%= product.sku %></small>
                <% if product.has_multiple_quantities? && product.product_variants.any? %>
                  <select class="form-select form-select-sm mb-2" id="st-variant-<%= product.id %>" onclick="event.stopPropagation()">
                    <option value="">— Select variant —</option>
                    <% product.product_variants.order(:display_order, :weight).each do |v| %>
                      <option value="<%= v.id %>" data-label="<%= v.label %>" data-stock="<%= v.available_stock %>">
                        <%= v.label %> (stock: <%= v.available_stock.to_i %>)
                      </option>
                    <% end %>
                  </select>
                <% end %>
                <div class="mt-auto">
                  <button type="button" class="btn btn-sm w-100 fw-semibold st-btn" id="st-btn-<%= product.id %>"
                          style="background:linear-gradient(135deg,#1C7C54,#10b981);color:white;border:none;border-radius:6px;"
                          onclick="event.stopPropagation(); stAddFromBtn(<%= product.id %>, '<%= j(product.name) %>', '<%= j(product.sku) %>', <%= stock %>, <%= product.has_multiple_quantities? %>)"
                          <%= 'disabled' if stock <= 0 %>>
                    <i class="bi bi-plus-circle me-1"></i>Add to Request
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <div id="stNoResults" class="text-center py-5 d-none">
        <i class="bi bi-search fs-1 text-muted mb-2"></i>
        <p class="text-muted">No products match your search.</p>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-box-seam fs-1 text-muted mb-3"></i>
        <h5 class="text-muted">No Products Available</h5>
      </div>
    <% end %>
  </div>
</div>

<%# Sticky Cart Panel %>
<div id="stPanel" class="d-none position-fixed bottom-0 start-0 w-100" style="z-index:1040;box-shadow:0 -4px 20px rgba(0,0,0,0.15);max-height:50vh;overflow-y:auto;">
  <div class="bg-white border-top">
    <div class="container-fluid px-4 py-3">

      <%# Panel Header %>
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="fw-bold">
          <i class="bi bi-cart3 me-2" style="color:#1C7C54;"></i>
          Transfer Request — <span id="stItemCount">0</span> product(s) selected
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="stClearAll()">
          <i class="bi bi-x me-1"></i>Clear All
        </button>
      </div>

      <%= form_tag store_admin_stock_transfers_path, method: :post, id: "stForm" do %>

        <%# Cart rows (populated by JS) %>
        <div id="stCartRows" class="mb-3"></div>
        <%# Hidden fields container %>
        <div id="stHiddenFields"></div>

        <%# Shared fields + Submit %>
        <div class="row g-3 align-items-end pt-2 border-top">
          <div class="col-md-3">
            <label class="form-label fw-semibold small mb-1">Transfer From</label>
            <select name="from_store_id" class="form-select form-select-sm">
              <option value="">Central Inventory (Main Stock)</option>
              <% @stores.each do |s| %>
                <option value="<%= s.id %>"><%= s.name %></option>
              <% end %>
            </select>
          </div>
          <div class="col-md-5">
            <label class="form-label fw-semibold small mb-1">Notes (optional)</label>
            <input type="text" name="notes" class="form-control form-control-sm" placeholder="Reason for this transfer request...">
          </div>
          <div class="col-md-4">
            <button type="submit" class="btn w-100 fw-semibold" style="background:linear-gradient(135deg,#1C7C54,#10b981);color:white;border-radius:8px;">
              <i class="bi bi-send me-1"></i>Submit Transfer Request (<span id="stSubmitCount">0</span>)
            </button>
          </div>
        </div>

      <% end %>
    </div>
  </div>
</div>

<script>
// stCart items: { key, productId, variantId, name, sku, stock, qty }
let stCart = [];
let stStockMode = 'all';

function stCartKey(productId, variantId) {
  return variantId ? `${productId}-v${variantId}` : `${productId}`;
}

// Called when card area is clicked (for non-variant products only)
function stToggle(id, name, sku, stock) {
  const hasVariant = !!document.getElementById('st-variant-' + id);
  if (hasVariant) return; // handled by stAddFromBtn
  if (stock <= 0) return;
  const key = stCartKey(id, null);
  const idx = stCart.findIndex(i => i.key === key);
  if (idx >= 0) {
    stCart.splice(idx, 1);
    stSetCardState(id, false);
  } else {
    stCart.push({ key, productId: id, variantId: null, variantLabel: null, name, sku, stock, qty: 1 });
    stSetCardState(id, true);
  }
  stRender();
}

// Called by "Add to Request" button (handles both variant and non-variant)
function stAddFromBtn(id, name, sku, stock, hasVariants) {
  if (hasVariants) {
    const sel = document.getElementById('st-variant-' + id);
    if (!sel || !sel.value) { alert('Please select a variant first.'); return; }
    const opt = sel.options[sel.selectedIndex];
    const variantId    = parseInt(sel.value);
    const variantLabel = opt.dataset.label;
    const variantStock = parseFloat(opt.dataset.stock) || 0;
    const key = stCartKey(id, variantId);
    if (stCart.find(i => i.key === key)) { alert('This variant is already in the request.'); return; }
    stCart.push({ key, productId: id, variantId, variantLabel, name, sku, stock: variantStock, qty: 1 });
  } else {
    if (stock <= 0) return;
    const key = stCartKey(id, null);
    if (stCart.find(i => i.key === key)) { stRemoveByKey(key); return; }
    stCart.push({ key, productId: id, variantId: null, variantLabel: null, name, sku, stock, qty: 1 });
  }
  stSetCardState(id, true);
  stRender();
}

function stSetCardState(id, selected) {
  const card = document.getElementById('st-card-' + id);
  const check = document.getElementById('st-check-' + id);
  const btn = document.getElementById('st-btn-' + id);
  const hasInCart = stCart.some(i => i.productId === id);
  if (selected || hasInCart) {
    card.classList.add('selected');
    check.classList.remove('d-none');
    if (btn) { btn.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Added'; btn.style.background = 'linear-gradient(135deg,#0f5e3e,#059669)'; }
  } else {
    card.classList.remove('selected');
    check.classList.add('d-none');
    if (btn) { btn.innerHTML = '<i class="bi bi-plus-circle me-1"></i>Add to Request'; btn.style.background = 'linear-gradient(135deg,#1C7C54,#10b981)'; }
  }
}

function stRender() {
  const panel  = document.getElementById('stPanel');
  const rows   = document.getElementById('stCartRows');
  const hidden = document.getElementById('stHiddenFields');
  const count  = stCart.length;
  document.getElementById('stItemCount').textContent = count;
  document.getElementById('stSubmitCount').textContent = count;

  if (count === 0) { panel.classList.add('d-none'); return; }
  panel.classList.remove('d-none');

  rows.innerHTML = stCart.map((item) => `
    <div class="st-cart-row d-flex align-items-center gap-3">
      <div class="flex-grow-1">
        <div class="fw-semibold small">${item.name}${item.variantLabel ? ` <span class="badge bg-primary-subtle text-primary ms-1" style="font-size:0.7rem;">${item.variantLabel}</span>` : ''}</div>
        <small class="text-muted">SKU: ${item.sku} &bull; Available: ${Math.floor(item.stock)}</small>
      </div>
      <div style="width:130px;">
        <div class="input-group input-group-sm">
          <button class="btn btn-outline-secondary" type="button" onclick="stDec('${item.key}')" style="border-radius:6px 0 0 6px;"><i class="bi bi-dash"></i></button>
          <input type="number" class="form-control text-center fw-bold" id="st-qty-${item.key}"
                 value="${item.qty}" min="1" step="1" max="${Math.floor(item.stock)}"
                 onchange="stQtyChange('${item.key}', this.value)" style="max-width:54px;">
          <button class="btn btn-outline-secondary" type="button" onclick="stInc('${item.key}')" style="border-radius:0 6px 6px 0;"><i class="bi bi-plus"></i></button>
        </div>
      </div>
      <button type="button" class="btn btn-sm btn-outline-danger" onclick="stRemoveByKey('${item.key}')" style="border-radius:6px;">
        <i class="bi bi-trash"></i>
      </button>
    </div>
  `).join('');

  hidden.innerHTML = stCart.map((item, i) => `
    <input type="hidden" name="transfers[${i}][product_id]" value="${item.productId}">
    <input type="hidden" name="transfers[${i}][quantity]" value="${item.qty}">
    ${item.variantId ? `<input type="hidden" name="transfers[${i}][variant_id]" value="${item.variantId}">` : ''}
  `).join('');
}

function stQtyChange(key, val) {
  const item = stCart.find(i => i.key === key);
  if (!item) return;
  item.qty = Math.min(Math.max(1, parseInt(val) || 1), Math.floor(item.stock));
  const input = document.getElementById('st-qty-' + key);
  if (input) input.value = item.qty;
  stRender();
}

function stInc(key) {
  const item = stCart.find(i => i.key === key);
  if (item && item.qty < Math.floor(item.stock)) { item.qty++; stRender(); }
}

function stDec(key) {
  const item = stCart.find(i => i.key === key);
  if (item && item.qty > 1) { item.qty--; stRender(); }
}

function stRemoveByKey(key) {
  const item = stCart.find(i => i.key === key);
  if (item) stSetCardState(item.productId, false);
  stCart = stCart.filter(i => i.key !== key);
  stRender();
}

function stClearAll() {
  stCart.forEach(item => stSetCardState(item.productId, false));
  stCart = [];
  stRender();
}

function stFilter() {
  const q   = document.getElementById('stSearch').value.toLowerCase();
  const cat = document.getElementById('stCatFilter').value;
  let vis = 0;
  document.querySelectorAll('.st-item').forEach(item => {
    const matchQ = !q || item.dataset.name.includes(q) || item.dataset.sku.includes(q);
    const matchC = !cat || item.dataset.category === cat;
    const matchS = stStockMode === 'all' || parseFloat(item.dataset.stock) > 0;
    const show = matchQ && matchC && matchS;
    item.style.display = show ? '' : 'none';
    if (show) vis++;
  });
  document.getElementById('stNoResults').classList.toggle('d-none', vis > 0);
}

function stStockFilter(mode) {
  stStockMode = mode;
  document.getElementById('stAllBtn').classList.toggle('active', mode === 'all');
  document.getElementById('stInStockBtn').classList.toggle('active', mode === 'instock');
  stFilter();
}

document.getElementById('stForm')?.addEventListener('submit', function(e) {
  if (stCart.length === 0) { e.preventDefault(); alert('Please select at least one product.'); }
});
</script>
