<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h5 class="fw-bold mb-1"><i class="bi bi-arrow-left-right me-2" style="color:#1C7C54;"></i>Request Stock Transfer</h5>
    <small class="text-muted">Request stock for <%= @current_store.name %></small>
  </div>
  <%= link_to store_admin_stock_transfers_path, class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Back
  <% end %>
</div>

<div class="card border-0 shadow-sm" style="border-radius:14px; max-width:560px;">
  <div class="card-body p-4">
    <%= form_tag store_admin_stock_transfers_path, method: :post do %>

      <div class="mb-3">
        <label class="form-label fw-semibold">Product <span class="text-danger">*</span></label>
        <select name="product_id" class="form-select" required>
          <option value="">-- Select Product --</option>
          <% @products.each do |p| %>
            <option value="<%= p.id %>"><%= p.name %> (<%= p.sku %>)</option>
          <% end %>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Transfer From</label>
        <select name="from_store_id" class="form-select">
          <option value="">Central Inventory (Main Stock)</option>
          <% @stores.each do |s| %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% end %>
        </select>
        <small class="text-muted">Leave as "Central Inventory" to request from main stock.</small>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Quantity <span class="text-danger">*</span></label>
        <input type="number" name="quantity" class="form-control" step="0.01" min="0.01" required placeholder="e.g. 10">
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Notes</label>
        <textarea name="notes" class="form-control" rows="2" placeholder="Reason for request..."></textarea>
      </div>

      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn fw-semibold" style="background:linear-gradient(135deg,#1C7C54,#10b981);color:white;border-radius:8px;padding:0.5rem 1.5rem;">
          <i class="bi bi-send me-1"></i>Submit Request
        </button>
        <%= link_to "Cancel", store_admin_stock_transfers_path, class: "btn btn-outline-secondary", style: "border-radius:8px;" %>
      </div>
    <% end %>
  </div>
</div>
