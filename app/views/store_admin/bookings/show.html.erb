<%- content_for :title, "Booking - #{@booking.booking_number || "##{@booking.id}"}" %>

<div class="row">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="card-title mb-0">Booking Details</h4>
        <div class="d-flex gap-2">
          <button onclick="window.print()" class="btn btn-success btn-sm">
            <i class="fas fa-print me-1"></i>Print Bill
          </button>
          <% if ['draft', 'confirmed'].include?(@booking.status) %>
            <%= link_to "Edit", edit_store_admin_booking_path(@booking), class: "btn btn-outline-primary btn-sm" %>
          <% end %>
          <%= link_to "Back to Bookings", store_admin_bookings_path, class: "btn btn-outline-secondary btn-sm" %>
        </div>
      </div>

      <div class="card-body">
        <div class="row mb-4">
          <div class="col-md-6">
            <h6 class="fw-semibold">Booking Information</h6>
            <table class="table table-borderless table-sm">
              <tr><td><strong>Booking #:</strong></td><td><%= @booking.booking_number || "##{@booking.id}" %></td></tr>
              <tr><td><strong>Store:</strong></td><td><%= @current_store.name %></td></tr>
              <tr><td><strong>Date:</strong></td><td><%= @booking.created_at.strftime("%d %b %Y at %I:%M %p") %></td></tr>
              <tr>
                <td><strong>Status:</strong></td>
                <td>
                  <% if ['delivered', 'completed'].include?(@booking.status) %>
                    <span class="badge bg-success"><%= @booking.status.humanize %></span>
                  <% elsif ['cancelled', 'returned'].include?(@booking.status) %>
                    <span class="badge bg-danger"><%= @booking.status.humanize %></span>
                  <% elsif ['draft', 'ordered_and_delivery_pending'].include?(@booking.status) %>
                    <span class="badge bg-warning text-dark"><%= @booking.status.humanize %></span>
                  <% else %>
                    <span class="badge bg-info"><%= @booking.status&.humanize || 'Unknown' %></span>
                  <% end %>
                </td>
              </tr>
              <tr>
                <td><strong>Payment:</strong></td>
                <td>
                  <% if @booking.payment_status == 'paid' %>
                    <span class="badge bg-success">Paid</span>
                  <% else %>
                    <span class="badge bg-warning text-dark">Unpaid</span>
                  <% end %>
                </td>
              </tr>
            </table>
          </div>

          <div class="col-md-6">
            <h6 class="fw-semibold">Customer Information</h6>
            <% if @booking.customer %>
              <table class="table table-borderless table-sm">
                <tr><td><strong>Name:</strong></td><td><%= @booking.customer.full_name rescue "#{@booking.customer.first_name} #{@booking.customer.last_name}" %></td></tr>
                <tr><td><strong>Mobile:</strong></td><td><%= @booking.customer.mobile %></td></tr>
                <tr><td><strong>Email:</strong></td><td><%= @booking.customer.email || 'N/A' %></td></tr>
              </table>
            <% else %>
              <p class="text-muted">Walk-in Customer</p>
            <% end %>
          </div>
        </div>

        <!-- Booking Items -->
        <div class="mb-4">
          <h6 class="fw-semibold">Ordered Items</h6>
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Quantity</th>
                  <th>Unit Price</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% @booking.booking_items.includes(:product).each do |item| %>
                  <tr>
                    <td><strong><%= item.product&.name %></strong></td>
                    <td><%= item.quantity %></td>
                    <td>₹<%= number_with_precision(item.price || 0, precision: 2) %></td>
                    <td><strong>₹<%= number_with_precision((item.quantity.to_f * (item.price || 0)), precision: 2) %></strong></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <% if @booking.notes.present? %>
          <div class="mb-4">
            <h6 class="fw-semibold">Notes</h6>
            <div class="border rounded p-3 bg-light"><%= simple_format(@booking.notes) %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <!-- Order Summary -->
    <div class="card">
      <div class="card-header"><h5 class="card-title mb-0">Order Summary</h5></div>
      <div class="card-body">
        <table class="table table-borderless">
          <tr><td>Subtotal:</td><td class="text-end">₹<%= number_with_precision(@booking.subtotal || @booking.total_amount || 0, precision: 2) %></td></tr>
          <% if @booking.discount_amount.to_f > 0 %>
            <tr><td>Discount:</td><td class="text-end text-success">-₹<%= number_with_precision(@booking.discount_amount, precision: 2) %></td></tr>
          <% end %>
          <tr class="border-top"><td><strong>Total:</strong></td><td class="text-end"><strong>₹<%= number_with_precision(@booking.total_amount || 0, precision: 2) %></strong></td></tr>
        </table>
        <div class="mt-2">
          <strong>Payment Method:</strong>
          <span class="ms-2 text-capitalize"><%= @booking.payment_method || 'Cash' %></span>
        </div>
      </div>
    </div>

    <!-- Update Status -->
    <% if @can_update_status && @available_statuses.any? %>
      <div class="card mt-3">
        <div class="card-header"><h5 class="card-title mb-0">Update Status</h5></div>
        <div class="card-body">
          <p class="small text-muted">Current: <strong><%= @booking.status&.humanize || 'Unknown' %></strong></p>
          <%= form_with url: update_status_store_admin_booking_path(@booking), method: :patch, local: true do |form| %>
            <div class="mb-3">
              <%= form.select :new_status,
                  options_for_select(@available_statuses.map { |s| [s.humanize, s] }),
                  { prompt: "Select new status..." },
                  { class: "form-select" } %>
            </div>
            <%= form.submit "Update Status", class: "btn btn-primary w-100" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Cancel -->
    <% if ['draft', 'confirmed'].include?(@booking.status) %>
      <div class="card mt-3">
        <div class="card-header bg-light"><h5 class="card-title mb-0 text-danger">Cancel Booking</h5></div>
        <div class="card-body">
          <%= form_with url: cancel_store_admin_booking_path(@booking), method: :patch, local: true do |form| %>
            <div class="mb-3">
              <%= form.text_area :cancellation_reason, placeholder: "Reason for cancellation...", class: "form-control", rows: 3, required: true %>
            </div>
            <%= form.submit "Cancel Booking", class: "btn btn-danger w-100",
                data: { confirm: "Are you sure? This cannot be undone." } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
@media print {
  .btn, .breadcrumb, .col-lg-4 { display: none !important; }
  .col-lg-8 { flex: 0 0 100% !important; max-width: 100% !important; }
  .card { border: none !important; box-shadow: none !important; }
}
</style>
