<%- content_for :title, "Edit Booking - #{@booking.booking_number || @booking.id}" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Edit Booking</h4>
    <small class="text-muted"><%= @booking.booking_number || "##{@booking.id}" %></small>
  </div>
  <%= link_to store_admin_booking_path(@booking), class: "btn btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-2"></i>Back to Booking
  <% end %>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <%= form_with model: [:store_admin, @booking], local: true do |f| %>
      <% if @booking.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @booking.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Customer</label>
          <%= f.collection_select :customer_id,
              (@customers || []),
              :id,
              :full_name,
              { include_blank: "-- Walk-in Customer --" },
              { class: "form-select" } %>
        </div>

        <div class="col-md-3">
          <label class="form-label">Payment Method</label>
          <%= f.select :payment_method,
              options_for_select([['Cash', 'cash'], ['UPI', 'upi'], ['Card', 'card'], ['Bank Transfer', 'bank_transfer']], @booking.payment_method),
              { include_blank: "Select Method" },
              { class: "form-select" } %>
        </div>

        <div class="col-md-3">
          <label class="form-label">Payment Status</label>
          <%= f.select :payment_status,
              options_for_select([['Unpaid', 'unpaid'], ['Paid', 'paid']], @booking.payment_status),
              {},
              { class: "form-select" } %>
        </div>

        <div class="col-md-4">
          <label class="form-label">Discount Amount</label>
          <div class="input-group">
            <span class="input-group-text">₹</span>
            <%= f.number_field :discount_amount, class: "form-control", step: 0.01, min: 0 %>
          </div>
        </div>

        <div class="col-12">
          <label class="form-label">Notes</label>
          <%= f.text_area :notes, class: "form-control", rows: 2 %>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <%= f.submit "Update Booking", class: "btn btn-primary" %>
        <%= link_to "Cancel", store_admin_booking_path(@booking), class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>
