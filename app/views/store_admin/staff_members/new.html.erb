<% content_for :page_title, "Add Staff" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Add Staff</h4>
    <small class="text-muted">Add a new staff member for <%= @current_store.name %></small>
  </div>
  <%= link_to store_admin_staff_members_path, class: "btn btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-2"></i>Back to Staff
  <% end %>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-person-plus me-2"></i>Staff Details</h6>
      </div>
      <div class="card-body">
        <%= render 'form', staff_member: @staff_member %>
      </div>
    </div>
  </div>
</div>
