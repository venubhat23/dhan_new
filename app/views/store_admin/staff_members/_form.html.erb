<%= form_with model: [:store_admin, staff_member], local: true do |f| %>
  <% if staff_member.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% staff_member.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <label class="form-label">Name <span class="text-danger">*</span></label>
      <%= f.text_field :name, class: "form-control", placeholder: "Staff full name", required: true %>
    </div>

    <div class="col-md-6">
      <label class="form-label">Designation</label>
      <%= f.text_field :designation, class: "form-control", placeholder: "e.g. Delivery Boy, Cashier" %>
    </div>

    <div class="col-md-6">
      <label class="form-label">Mobile</label>
      <%= f.text_field :mobile, class: "form-control", placeholder: "10-digit mobile number" %>
    </div>

    <div class="col-md-6">
      <label class="form-label">Email</label>
      <%= f.email_field :email, class: "form-control", placeholder: "Optional" %>
    </div>

    <div class="col-md-6">
      <label class="form-label">Monthly Salary <span class="text-danger">*</span></label>
      <div class="input-group">
        <span class="input-group-text">₹</span>
        <%= f.number_field :monthly_salary, class: "form-control", step: 0.01, min: 0, required: true %>
      </div>
    </div>

    <div class="col-md-6">
      <label class="form-label">Joining Date</label>
      <%= f.date_field :joining_date, class: "form-control" %>
    </div>

    <div class="col-12">
      <label class="form-label">Notes</label>
      <%= f.text_area :notes, class: "form-control", rows: 3, placeholder: "Optional notes..." %>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit staff_member.persisted? ? "Update Staff" : "Add Staff", class: "btn btn-primary" %>
    <%= link_to "Cancel", store_admin_staff_members_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
