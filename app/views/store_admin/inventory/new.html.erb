<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h5 class="fw-bold mb-1"><i class="bi bi-box-arrow-in-down me-2" style="color:#1C7C54;"></i>Receive Stock</h5>
    <small class="text-muted">Add new stock to <%= @current_store.name %></small>
  </div>
  <%= link_to store_admin_inventory_index_path, class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i>Back to Inventory
  <% end %>
</div>

<div class="card border-0 shadow-sm" style="border-radius:14px; max-width:600px;">
  <div class="card-body p-4">
    <%= form_tag store_admin_inventory_index_path, method: :post do %>

      <div class="mb-3">
        <label class="form-label fw-semibold">Product <span class="text-danger">*</span></label>
        <select name="product_id" id="product_select" class="form-select" required>
          <option value="">-- Select Product --</option>
          <% @products.each do |p| %>
            <option value="<%= p.id %>" <%= 'selected' if params[:product_id].to_i == p.id %>
                    data-price="<%= p.price %>" data-buying="<%= p.buying_price %>" data-unit="<%= p.unit_type %>">
              <%= p.name %> (<%= p.sku %>)
            </option>
          <% end %>
        </select>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold">Quantity <span class="text-danger">*</span></label>
          <div class="input-group">
            <input type="number" name="quantity" id="quantity_input" class="form-control" step="0.01" min="0.01" required placeholder="0">
            <span class="input-group-text unit-label">units</span>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Purchase Price (₹)</label>
          <input type="number" name="purchase_price" id="purchase_price" class="form-control" step="0.01" min="0" placeholder="Cost per unit">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Selling Price (₹)</label>
          <input type="number" name="selling_price" id="selling_price" class="form-control" step="0.01" min="0" placeholder="Price per unit">
        </div>
      </div>

      <% if @vendors.any? %>
      <div class="mb-3">
        <label class="form-label fw-semibold">Vendor</label>
        <select name="vendor_id" class="form-select">
          <option value="">-- Default Vendor --</option>
          <% @vendors.each do |v| %>
            <option value="<%= v.id %>"><%= v.name %></option>
          <% end %>
        </select>
      </div>
      <% end %>

      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn fw-semibold" style="background:linear-gradient(135deg,#1C7C54,#10b981);color:white;border-radius:8px;padding:0.5rem 1.5rem;">
          <i class="bi bi-check-lg me-1"></i>Add to Stock
        </button>
        <%= link_to "Cancel", store_admin_inventory_index_path, class: "btn btn-outline-secondary", style: "border-radius:8px;" %>
      </div>
    <% end %>
  </div>
</div>

<script>
document.getElementById('product_select').addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  document.getElementById('purchase_price').value = opt.dataset.buying || '';
  document.getElementById('selling_price').value = opt.dataset.price || '';
  document.querySelector('.unit-label').textContent = opt.dataset.unit || 'units';
});
</script>
