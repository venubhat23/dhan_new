<style>
  .dashboard-metric-card { min-height: 120px !important; }
  .dashboard-metric-card .d-flex { display: flex !important; }
  .dashboard-metric-card .card-body { padding: 1.5rem !important; }
  div.dashboard-metric-card.card-blue { background-color: #0d6efd !important; }
  div.dashboard-metric-card.card-yellow { background-color: #ffc107 !important; }
  div.dashboard-metric-card.card-cyan { background-color: #0dcaf0 !important; }
  div.dashboard-metric-card.card-green { background-color: #198754 !important; }
</style>

<div class="row mb-4">
  <div class="col-md-3 mb-3">
    <div class="card dashboard-metric-card card-blue border-0 shadow-sm" style="background: #0d6efd !important; color: white !important; min-height: 120px !important;">
      <div class="card-body" style="background: transparent !important; padding: 1.5rem !important;">
        <div class="d-flex justify-content-between align-items-center" style="display: flex !important;">
          <div>
            <h5 class="card-title mb-1" style="color: white !important; font-weight: 600 !important; font-size: 1rem !important;">Total Bookings</h5>
            <h3 class="mb-0" style="color: white !important; font-weight: 700 !important; font-size: 2rem !important;"><%= @inventory_summary[:recent_bookings_count] || 0 %></h3>
            <small style="color: rgba(255,255,255,0.8)">This week</small>
          </div>
          <i class="bi bi-cart-check" style="color: rgba(255,255,255,0.5) !important; font-size: 3rem !important;"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3">
    <div class="card dashboard-metric-card card-yellow border-0 shadow-sm" style="background: #ffc107 !important; color: #212529 !important; min-height: 120px !important;">
      <div class="card-body" style="background: transparent !important; padding: 1.5rem !important;">
        <div class="d-flex justify-content-between align-items-center" style="display: flex !important;">
          <div>
            <h5 class="card-title mb-1" style="color: #212529 !important; font-weight: 600 !important; font-size: 1rem !important;">Today's Revenue</h5>
            <h3 class="mb-0" style="color: #212529 !important; font-weight: 700 !important; font-size: 1.6rem !important;">
              ₹<%= number_with_delimiter(@daily_sales.last[:sales].to_f.round) %>
            </h3>
            <small style="color: rgba(33,37,41,0.6)">Today</small>
          </div>
          <i class="bi bi-currency-rupee" style="color: rgba(33,37,41,0.3) !important; font-size: 3rem !important;"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3">
    <div class="card dashboard-metric-card card-cyan border-0 shadow-sm" style="background: #0dcaf0 !important; color: white !important; min-height: 120px !important;">
      <div class="card-body" style="background: transparent !important; padding: 1.5rem !important;">
        <div class="d-flex justify-content-between align-items-center" style="display: flex !important;">
          <div>
            <h5 class="card-title mb-1" style="color: white !important; font-weight: 600 !important; font-size: 1rem !important;">Pending</h5>
            <h3 class="mb-0" style="color: white !important; font-weight: 700 !important; font-size: 2rem !important;">
              <%= @current_store.bookings.where(status: ['draft', 'ordered_and_delivery_pending', 'confirmed']).count %>
            </h3>
            <small style="color: rgba(255,255,255,0.8)">Needs action</small>
          </div>
          <i class="bi bi-hourglass-split" style="color: rgba(255,255,255,0.5) !important; font-size: 3rem !important;"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3">
    <div class="card dashboard-metric-card card-green border-0 shadow-sm" style="background: #198754 !important; color: white !important; min-height: 120px !important;">
      <div class="card-body" style="background: transparent !important; padding: 1.5rem !important;">
        <div class="d-flex justify-content-between align-items-center" style="display: flex !important;">
          <div>
            <h5 class="card-title mb-1" style="color: white !important; font-weight: 600 !important; font-size: 1rem !important;">Completed</h5>
            <h3 class="mb-0" style="color: white !important; font-weight: 700 !important; font-size: 2rem !important;">
              <%= @current_store.bookings.where(status: ['delivered', 'completed']).count %>
            </h3>
            <small style="color: rgba(255,255,255,0.8)">All time</small>
          </div>
          <i class="bi bi-check-circle" style="color: rgba(255,255,255,0.5) !important; font-size: 3rem !important;"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <!-- Recent Bookings -->
  <div class="col-md-8 mb-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold">
          <i class="bi bi-cart-check text-primary me-2"></i>Recent Bookings
        </h6>
        <%= link_to "View All", store_admin_bookings_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="card-body p-0">
        <% if @recent_bookings.any? %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Booking #</th>
                  <th>Customer</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% @recent_bookings.each do |booking| %>
                  <tr>
                    <td><%= link_to (booking.booking_number || "##{booking.id}"), store_admin_booking_path(booking), class: "fw-bold text-decoration-none" %></td>
                    <td>
                      <% if booking.customer %>
                        <%= booking.customer.full_name rescue booking.customer.try(:first_name) %>
                      <% else %>
                        <span class="text-muted">Walk-in</span>
                      <% end %>
                    </td>
                    <td><strong>₹<%= number_with_delimiter(booking.total_amount.to_f.round) %></strong></td>
                    <td>
                      <% case booking.status %>
                      <% when 'delivered', 'completed' %>
                        <span class="badge bg-success"><%= booking.status.humanize %></span>
                      <% when 'cancelled', 'returned' %>
                        <span class="badge bg-danger"><%= booking.status.humanize %></span>
                      <% when 'draft', 'ordered_and_delivery_pending' %>
                        <span class="badge bg-warning text-dark"><%= booking.status.humanize %></span>
                      <% else %>
                        <span class="badge bg-info"><%= booking.status&.humanize || 'Unknown' %></span>
                      <% end %>
                    </td>
                    <td><small><%= booking.created_at.strftime("%d %b %Y") %></small></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-cart-x fs-1 text-muted"></i>
            <p class="mt-2 mb-0">No bookings yet</p>
            <%= link_to "Create First Booking", new_store_admin_booking_path, class: "btn btn-primary btn-sm mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Store Info & Quick Actions -->
  <div class="col-md-4 mb-4">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0 fw-bold"><i class="bi bi-building me-2"></i>Store Info</h6>
      </div>
      <div class="card-body">
        <table class="table table-borderless table-sm mb-0">
          <tr><td class="text-muted">Name:</td><td><strong><%= @current_store.name %></strong></td></tr>
          <tr><td class="text-muted">City:</td><td><%= @current_store.city %>, <%= @current_store.state %></td></tr>
          <tr><td class="text-muted">Contact:</td><td><%= @current_store.contact_mobile %></td></tr>
          <tr><td class="text-muted">GST:</td><td><%= @current_store.gst_no.presence || 'N/A' %></td></tr>
        </table>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0 fw-bold"><i class="bi bi-lightning me-2"></i>Quick Actions</h6>
      </div>
      <div class="card-body d-grid gap-2">
        <%= link_to new_store_admin_booking_path, class: "btn btn-primary btn-sm" do %>
          <i class="bi bi-plus-circle me-2"></i>New Booking
        <% end %>
        <%= link_to new_store_admin_expense_path, class: "btn btn-outline-secondary btn-sm" do %>
          <i class="bi bi-receipt me-2"></i>Add Expense
        <% end %>
        <%= link_to store_admin_bookings_path, class: "btn btn-outline-primary btn-sm" do %>
          <i class="bi bi-list me-2"></i>All Bookings
        <% end %>
      </div>
    </div>
  </div>
</div>
