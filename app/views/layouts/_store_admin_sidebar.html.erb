<style>
.modern-sidebar {
  position: fixed !important;
  top: 70px !important;
  left: 0 !important;
  width: 260px !important;
  height: calc(100vh - 70px) !important;
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 50%, #f1f5f9 100%) !important;
  border-right: 2px solid #e2e8f0 !important;
  z-index: 1040 !important;
  overflow: hidden !important;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1) !important;
  display: flex !important;
  flex-direction: column !important;
}

.nav-link-modern {
  display: flex !important;
  align-items: center !important;
  padding: 12px 20px !important;
  margin: 6px 12px !important;
  border-radius: 16px !important;
  color: #64748b !important;
  font-weight: 500 !important;
  text-decoration: none !important;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  overflow: hidden !important;
  background: rgba(248, 250, 252, 0.8) !important;
  border: 1px solid rgba(226, 232, 240, 0.8) !important;
}

.nav-link-modern:hover {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%) !important;
  color: #1e293b !important;
  transform: translateY(-2px) !important;
  box-shadow: 0 12px 30px rgba(59, 130, 246, 0.15) !important;
  border: 1px solid rgba(59, 130, 246, 0.2) !important;
}

.nav-link-modern.active {
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%) !important;
  color: #ffffff !important;
  box-shadow: 0 12px 30px rgba(59, 130, 246, 0.3) !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
  transform: translateY(-2px) !important;
}

.nav-link-modern.active .nav-text { color: #ffffff !important; font-weight: 600 !important; }
.nav-link-modern.active .icon-bg { background: rgba(255, 255, 255, 0.2) !important; }

.nav-text {
  color: #64748b !important;
  font-weight: 500 !important;
  margin-left: 12px !important;
  font-size: 14px !important;
  display: inline-block !important;
  transition: all 0.3s ease !important;
}

.nav-link-modern:hover .nav-text { color: #1e293b !important; font-weight: 600 !important; }

.nav-section-title {
  color: #3b82f6 !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 1px !important;
  margin: 20px 12px 8px 12px !important;
  padding: 8px 12px !important;
  background: rgba(59, 130, 246, 0.08) !important;
  border-radius: 12px !important;
  border: 1px solid rgba(59, 130, 246, 0.15) !important;
}

.sidebar-header {
  padding: 20px 12px 15px 12px !important;
  border-bottom: 1px solid rgba(226, 232, 240, 0.8) !important;
  background: rgba(248, 250, 252, 0.9) !important;
  margin-bottom: 10px !important;
}

.store-info-card {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%) !important;
  border: 1px solid rgba(59, 130, 246, 0.2) !important;
  border-radius: 16px !important;
  padding: 16px !important;
}

.store-admin-brand {
  color: #1e293b !important;
  font-size: 18px !important;
  font-weight: 700 !important;
  margin-bottom: 8px !important;
}

.store-details {
  color: #64748b !important;
  font-size: 12px !important;
  font-weight: 500 !important;
}

.icon-bg {
  width: 32px !important;
  height: 32px !important;
  border-radius: 10px !important;
  background: rgba(226, 232, 240, 0.6) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 16px !important;
  transition: all 0.3s ease !important;
  color: #64748b !important;
}

.sidebar-footer {
  margin-top: auto !important;
  padding: 20px 12px !important;
  border-top: 1px solid rgba(226, 232, 240, 0.8) !important;
  background: rgba(248, 250, 252, 0.9) !important;
}

.sidebar-scrollable {
  flex: 1 !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
  padding: 10px 0 !important;
}

.sidebar-scrollable::-webkit-scrollbar { width: 4px !important; }
.sidebar-scrollable::-webkit-scrollbar-track { background: transparent !important; }
.sidebar-scrollable::-webkit-scrollbar-thumb { background: rgba(59, 130, 246, 0.3) !important; border-radius: 4px !important; }
</style>

<aside id="sidebar" class="modern-sidebar">
  <div class="sidebar-header">
    <div class="store-info-card">
      <div class="store-admin-brand">
        <i class="fas fa-store me-2"></i>
        <%= @current_store&.name || 'Store Admin' %>
      </div>
      <div class="store-details">
        <%= @current_store&.city %>, <%= @current_store&.state %>
      </div>
      <div class="store-details mt-1">
        <i class="fas fa-user-circle me-1"></i>
        <%= current_user.first_name %> <%= current_user.last_name %>
      </div>
    </div>
  </div>

  <div class="sidebar-scrollable">
    <div class="nav-section-title">
      <i class="fas fa-store me-2"></i>Store Management
    </div>

    <%= link_to store_admin_root_path,
        class: "nav-link-modern #{'active' if current_page?(store_admin_root_path)}" do %>
      <div class="icon-bg"><i class="bi bi-speedometer2"></i></div>
      <span class="nav-text">Dashboard</span>
    <% end %>

    <%= link_to store_admin_bookings_path,
        class: "nav-link-modern #{'active' if controller_name == 'bookings'}" do %>
      <div class="icon-bg"><i class="bi bi-cart-check"></i></div>
      <span class="nav-text">Bookings</span>
    <% end %>

    <%= link_to store_admin_expenses_path,
        class: "nav-link-modern #{'active' if controller_name == 'expenses'}" do %>
      <div class="icon-bg"><i class="bi bi-receipt"></i></div>
      <span class="nav-text">Expenses</span>
    <% end %>

    <% if current_user.can_manage_inventory? %>
      <div class="nav-section-title">
        <i class="fas fa-boxes me-2"></i>Inventory
      </div>

      <%= link_to store_admin_inventory_index_path,
          class: "nav-link-modern #{'active' if controller_name == 'inventory'}" do %>
        <div class="icon-bg"><i class="bi bi-boxes"></i></div>
        <span class="nav-text">Stock Levels</span>
      <% end %>

      <%= link_to store_admin_stock_transfers_path,
          class: "nav-link-modern #{'active' if controller_name == 'stock_transfers'}" do %>
        <div class="icon-bg"><i class="bi bi-arrow-left-right"></i></div>
        <span class="nav-text">Stock Transfers</span>
      <% end %>
    <% end %>
  </div>

  <div class="sidebar-footer">
    <div class="d-grid gap-2">
      <%= link_to destroy_user_session_path,
          class: "btn btn-outline-danger btn-sm",
          data: { confirm: "Are you sure you want to logout?", turbo_method: :delete } do %>
        <i class="fas fa-sign-out-alt me-2"></i>Logout
      <% end %>
    </div>
  </div>
</aside>
