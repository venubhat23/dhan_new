<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Dhanvantri Naturals</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <%= csrf_meta_tags %>
  <style>
    * { -webkit-tap-highlight-color: transparent; }
    body {
      background: #f0f2f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      overscroll-behavior: none;
      min-height: 100vh;
    }
    .mobile-header {
      background: linear-gradient(135deg, #6f42c1 0%, #4a148c 100%);
      color: white;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .mobile-header .brand { font-size: 1.05rem; font-weight: 700; letter-spacing: 0.3px; }
    .mobile-header .sub-brand { font-size: 0.7rem; opacity: 0.8; }
    .mobile-content { padding-bottom: 80px; }
    .fab {
      position: fixed;
      bottom: 24px;
      right: 20px;
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: linear-gradient(135deg, #6f42c1 0%, #4a148c 100%);
      color: white;
      border: none;
      font-size: 1.6rem;
      box-shadow: 0 4px 18px rgba(111,66,193,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      z-index: 200;
      transition: transform 0.15s;
    }
    .fab:hover, .fab:active { transform: scale(0.93); color: white; }
    .flash-msg {
      position: fixed;
      top: 65px;
      left: 10px;
      right: 10px;
      z-index: 999;
      border-radius: 10px;
      font-size: 0.9rem;
      animation: fadeInDown 0.3s ease;
    }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <%# Header — only shown when logged in %>
  <% if session[:mobile_ui_auth] %>
    <div class="mobile-header px-3 py-2">
      <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
          <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center"
               style="width:36px;height:36px;">
            <i class="bi bi-bag-heart-fill text-white fs-5"></i>
          </div>
          <div>
            <div class="brand">Dhanvantri Naturals</div>
            <div class="sub-brand">Admin Mobile</div>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <%= link_to admin_mobile_ui_bookings_path, class: "btn btn-sm btn-light btn-outline-light text-white border-white border-opacity-50 py-1 px-2" do %>
            <i class="bi bi-list-ul me-1"></i>Bookings
          <% end %>
          <%= link_to admin_mobile_ui_logout_path,
              class: "btn btn-sm btn-outline-light border-white border-opacity-50 text-white py-1 px-2" do %>
            <i class="bi bi-box-arrow-right"></i>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Flash messages %>
  <% if flash[:error].present? %>
    <div class="flash-msg alert alert-danger alert-dismissible mb-0" role="alert">
      <i class="bi bi-exclamation-circle me-2"></i><%= flash[:error] %>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
  <% end %>
  <% if flash[:notice].present? %>
    <div class="flash-msg alert alert-success alert-dismissible mb-0" role="alert">
      <i class="bi bi-check-circle me-2"></i><%= flash[:notice] %>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <div class="mobile-content">
    <%= yield %>
  </div>

  <% if session[:mobile_ui_auth] %>
    <%= link_to new_admin_booking_path, class: "fab", title: "New Booking" do %>
      <i class="bi bi-plus-lg"></i>
    <% end %>
  <% end %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Auto-dismiss flash after 3s
    setTimeout(() => {
      document.querySelectorAll('.flash-msg').forEach(el => {
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.4s';
        setTimeout(() => el.remove(), 400);
      });
    }, 3000);
  </script>
</body>
</html>
