<%# Profit & Loss Report %>
<div class="page-header d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1><i class="bi bi-graph-up-arrow me-2"></i>Profit & Loss Report</h1>
    <p class="text-muted mb-0">Products sold and profit/loss per date range</p>
  </div>
  <%= link_to admin_reports_profit_loss_path(from_date: @from_date, to_date: @to_date, download: 'csv'),
              class: "btn btn-success" do %>
    <i class="bi bi-file-earmark-arrow-down me-1"></i> Download CSV
  <% end %>
</div>

<!-- Date Range Filter -->
<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0"><i class="bi bi-calendar-range me-2"></i>Date Range</h5>
  </div>
  <div class="card-body">
    <%= form_with url: admin_reports_profit_loss_path, method: :get, local: true, class: "row g-3 align-items-end" do |f| %>
      <div class="col-md-4">
        <%= f.label :from_date, "From Date", class: "form-label fw-semibold" %>
        <%= f.date_field :from_date, value: @from_date, class: "form-control", required: true %>
      </div>
      <div class="col-md-4">
        <%= f.label :to_date, "To Date", class: "form-label fw-semibold" %>
        <%= f.date_field :to_date, value: @to_date, class: "form-control", required: true %>
      </div>
      <div class="col-md-4">
        <%= f.submit "Generate Report", class: "btn btn-primary w-100" %>
      </div>
    <% end %>
  </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card text-center border-0 shadow-sm">
      <div class="card-body py-3">
        <div class="text-muted small">Total Products</div>
        <div class="fs-4 fw-bold"><%= @product_rows.size %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-0 shadow-sm">
      <div class="card-body py-3">
        <div class="text-muted small">Total Revenue</div>
        <div class="fs-4 fw-bold text-primary">₹<%= number_with_delimiter(@totals[:revenue].round(2)) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-0 shadow-sm">
      <div class="card-body py-3">
        <div class="text-muted small">Total Cost</div>
        <div class="fs-4 fw-bold text-warning">₹<%= number_with_delimiter(@totals[:cost].round(2)) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <% net = @totals[:profit] %>
    <div class="card text-center border-0 shadow-sm">
      <div class="card-body py-3">
        <div class="text-muted small">Net <%= net >= 0 ? 'Profit' : 'Loss' %></div>
        <div class="fs-4 fw-bold <%= net >= 0 ? 'text-success' : 'text-danger' %>">
          ₹<%= number_with_delimiter(net.abs.round(2)) %>
          <small class="fs-6"><%= net >= 0 ? '▲' : '▼' %></small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Products Table -->
<div class="card shadow-sm">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Product-wise Breakdown</h5>
    <span class="badge bg-secondary"><%= @from_date.strftime('%d %b %Y') %> – <%= @to_date.strftime('%d %b %Y') %></span>
  </div>
  <div class="card-body p-0">
    <% if @product_rows.empty? %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1"></i>
        <p class="mt-2">No sales data found for the selected date range.</p>
      </div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Product</th>
              <th class="text-center">Qty Sold</th>
              <th class="text-end">Selling Price</th>
              <th class="text-end">Cost Price</th>
              <th class="text-end">Purchase Price</th>
              <th class="text-end">Revenue</th>
              <th class="text-end">Cost</th>
              <th class="text-end">Profit / Loss</th>
            </tr>
          </thead>
          <tbody>
            <% @product_rows.each_with_index do |row, i| %>
              <% profit = row[:profit] %>
              <tr>
                <td class="text-muted small"><%= i + 1 %></td>
                <td>
                  <strong><%= row[:name] %></strong>
                  <span class="badge bg-light text-dark ms-1"><%= row[:unit_type] %></span>
                </td>
                <td class="text-center fw-semibold"><%= row[:qty_sold].to_s.sub(/\.0$/, '') %></td>
                <td class="text-end">₹<%= number_with_delimiter(row[:selling_price].round(2)) %></td>
                <td class="text-end">₹<%= number_with_delimiter(row[:cost_price].round(2)) %></td>
                <td class="text-end">₹<%= number_with_delimiter(row[:purchase_price].round(2)) %></td>
                <td class="text-end text-primary fw-semibold">₹<%= number_with_delimiter(row[:revenue].round(2)) %></td>
                <td class="text-end text-warning fw-semibold">₹<%= number_with_delimiter(row[:cost].round(2)) %></td>
                <td class="text-end fw-bold <%= profit >= 0 ? 'text-success' : 'text-danger' %>">
                  <%= profit >= 0 ? '+' : '-' %>₹<%= number_with_delimiter(profit.abs.round(2)) %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="table-secondary fw-bold">
            <tr>
              <td colspan="2">TOTAL</td>
              <td class="text-center"><%= @totals[:qty_sold].to_s.sub(/\.0$/, '') %></td>
              <td></td>
              <td></td>
              <td></td>
              <td class="text-end text-primary">₹<%= number_with_delimiter(@totals[:revenue].round(2)) %></td>
              <td class="text-end text-warning">₹<%= number_with_delimiter(@totals[:cost].round(2)) %></td>
              <% net = @totals[:profit] %>
              <td class="text-end <%= net >= 0 ? 'text-success' : 'text-danger' %>">
                <%= net >= 0 ? '+' : '-' %>₹<%= number_with_delimiter(net.abs.round(2)) %>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% end %>
  </div>
</div>
