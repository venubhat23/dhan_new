<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h4 class="fw-bold mb-0"><i class="bi bi-qr-code me-2"></i>Product QR Codes</h4>
      <small class="text-muted">Print QR codes for all products</small>
    </div>
    <button class="btn btn-success" onclick="window.print()">
      <i class="bi bi-printer me-1"></i> Print All
    </button>
  </div>

  <%= form_with url: admin_qr_codes_path, method: :get, local: true, class: "mb-3" do |f| %>
    <div class="input-group" style="max-width: 350px;">
      <%= f.text_field :search, value: params[:search], class: "form-control", placeholder: "Search by name or barcode..." %>
      <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
      <% if params[:search].present? %>
        <%= link_to admin_qr_codes_path, class: "btn btn-outline-danger" do %><i class="bi bi-x"></i><% end %>
      <% end %>
    </div>
  <% end %>

  <div class="table-responsive d-print-none">
    <table class="table table-bordered table-hover align-middle">
      <thead class="table-dark">
        <tr>
          <th>Product Name</th>
          <th>Barcode</th>
          <th>SKU</th>
          <th>Category</th>
          <th class="text-center">QR Code</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td class="fw-semibold"><%= product.name %></td>
            <td><code><%= product.barcode %></code></td>
            <td><%= product.sku %></td>
            <td><%= product.category&.name %></td>
            <td class="text-center" style="width: 120px;">
              <%= product.qr_code_svg.html_safe %>
            </td>
          </tr>
        <% end %>
        <% if @products.empty? %>
          <tr>
            <td colspan="5" class="text-center text-muted py-4">No products found</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# Print layout — grid of QR cards, 4 per row %>
<style>
  @media print {
    .d-print-none { display: none !important; }
    .print-grid { display: flex !important; flex-wrap: wrap; gap: 12px; }
    .print-card { border: 1px solid #ccc; border-radius: 6px; padding: 10px; text-align: center; width: 22%; box-sizing: border-box; }
    .print-card svg { width: 100px; height: 100px; }
    .navbar, .sidebar, footer, .btn { display: none !important; }
    body { margin: 0; }
  }
</style>

<div class="print-grid" style="display:none;">
  <% @products.each do |product| %>
    <div class="print-card">
      <%= product.qr_code_svg.html_safe %>
      <div style="font-size:11px; font-weight:bold; margin-top:4px;"><%= product.name %></div>
      <div style="font-size:10px; color:#555;"><%= product.barcode %></div>
    </div>
  <% end %>
</div>
