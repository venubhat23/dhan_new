<style>
.store-dashboard { font-family: inherit; }

/* Hero header */
.dashboard-hero {
  background: linear-gradient(135deg, #1C7C54 0%, #10b981 100%);
  border-radius: 16px;
  padding: 2rem 2.5rem;
  color: white;
  margin-bottom: 2rem;
  position: relative;
  overflow: hidden;
}
.dashboard-hero::after {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 180px; height: 180px;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}
.dashboard-hero::before {
  content: '';
  position: absolute;
  bottom: -60px; right: 80px;
  width: 220px; height: 220px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
}
.hero-icon {
  width: 56px; height: 56px;
  background: rgba(255,255,255,0.2);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem;
  margin-bottom: 1rem;
}

/* Stat cards */
.stat-card {
  border: none;
  border-radius: 14px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
  overflow: hidden;
}
.stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
.stat-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
}

/* Store cards */
.store-card {
  border: none;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
  overflow: hidden;
}
.store-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
.store-card-header {
  background: linear-gradient(135deg, #f8f9fa, #fff);
  padding: 1.5rem;
  border-bottom: 1px solid #f0f0f0;
}
.store-avatar {
  width: 52px; height: 52px;
  background: linear-gradient(135deg, #1C7C54, #10b981);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem;
  color: white;
  flex-shrink: 0;
}
.store-info-row {
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.875rem; color: #6c757d;
  margin-bottom: 0.4rem;
}
.store-info-row i { width: 16px; color: #1C7C54; }
.status-pill {
  padding: 0.3rem 0.85rem;
  border-radius: 50px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.3px;
}
.store-action-btn {
  border-radius: 8px;
  font-size: 0.8rem;
  padding: 0.4rem 0.8rem;
  font-weight: 500;
  transition: all 0.2s;
}
.store-action-btn:hover { transform: translateY(-1px); }

/* Empty state */
.empty-state {
  padding: 5rem 2rem;
  text-align: center;
}
.empty-icon-wrap {
  width: 100px; height: 100px;
  background: linear-gradient(135deg, rgba(28,124,84,0.1), rgba(16,185,129,0.1));
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 1.5rem;
  font-size: 2.5rem;
}

/* Create store btn */
.btn-create-store {
  background: linear-gradient(135deg, #1C7C54, #10b981);
  color: white;
  border: none;
  border-radius: 10px;
  padding: 0.6rem 1.5rem;
  font-weight: 600;
  transition: all 0.3s;
  box-shadow: 0 4px 12px rgba(28,124,84,0.3);
}
.btn-create-store:hover {
  background: linear-gradient(135deg, #155c3e, #059669);
  color: white;
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(28,124,84,0.4);
}

/* Search */
.search-box {
  border-radius: 10px;
  border: 1.5px solid #e9ecef;
  padding: 0.5rem 1rem 0.5rem 2.5rem;
  font-size: 0.875rem;
  transition: border-color 0.2s;
}
.search-box:focus { border-color: #1C7C54; box-shadow: 0 0 0 3px rgba(28,124,84,0.1); outline: none; }

@media (max-width: 768px) {
  .dashboard-hero { padding: 1.5rem; }
}
</style>

<div class="store-dashboard">

  <!-- Hero Header -->
  <div class="dashboard-hero mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
      <div>
        <div class="hero-icon">
          <i class="bi bi-shop"></i>
        </div>
        <h2 class="fw-bold mb-1" style="font-size:1.8rem;">Store Dashboard</h2>
        <p class="mb-0 opacity-75">Manage all your retail stores and pickup locations</p>
      </div>
      <div class="d-flex gap-2 align-items-center mt-2">
        <%= link_to new_admin_store_path, class: "btn btn-light fw-semibold px-4 py-2", style: "border-radius:10px; color:#1C7C54;" do %>
          <i class="bi bi-plus-lg me-2"></i>Create Store
        <% end %>
      </div>
    </div>
  </div>

  <!-- Stat Cards -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="card stat-card h-100">
        <div class="card-body p-3 d-flex align-items-center gap-3">
          <div class="stat-icon bg-primary bg-opacity-10">
            <i class="bi bi-shop text-primary"></i>
          </div>
          <div>
            <div class="text-muted small fw-medium">Total Stores</div>
            <div class="fw-bold fs-4"><%= @stores.count %></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card stat-card h-100">
        <div class="card-body p-3 d-flex align-items-center gap-3">
          <div class="stat-icon bg-success bg-opacity-10">
            <i class="bi bi-check-circle text-success"></i>
          </div>
          <div>
            <div class="text-muted small fw-medium">Active</div>
            <div class="fw-bold fs-4 text-success"><%= @stores.where(status: true).count %></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card stat-card h-100">
        <div class="card-body p-3 d-flex align-items-center gap-3">
          <div class="stat-icon bg-danger bg-opacity-10">
            <i class="bi bi-x-circle text-danger"></i>
          </div>
          <div>
            <div class="text-muted small fw-medium">Inactive</div>
            <div class="fw-bold fs-4 text-danger"><%= @stores.where(status: false).count %></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card stat-card h-100">
        <div class="card-body p-3 d-flex align-items-center gap-3">
          <div class="stat-icon" style="background:rgba(28,124,84,0.1);">
            <i class="bi bi-infinity" style="color:#1C7C54;"></i>
          </div>
          <div>
            <div class="text-muted small fw-medium">Store Limit</div>
            <div class="fw-bold fs-5" style="color:#1C7C54;">Unlimited</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Store List -->
  <div class="card border-0 shadow-sm" style="border-radius:16px; overflow:hidden;">
    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center px-4 py-3">
      <h5 class="mb-0 fw-semibold">
        <i class="bi bi-building me-2 text-muted"></i>All Stores
        <span class="badge bg-secondary-subtle text-secondary ms-2" style="font-size:0.75rem;"><%= @stores.count %></span>
      </h5>
      <div class="d-flex gap-2 align-items-center">
        <div class="position-relative">
          <i class="bi bi-search position-absolute top-50 translate-middle-y ms-2 text-muted" style="left:4px; font-size:0.85rem;"></i>
          <input type="text" class="form-control search-box" id="storeSearch"
                 placeholder="Search stores..." style="width:220px; padding-left:2rem;">
        </div>
        <%= link_to new_admin_store_path, class: "btn btn-create-store btn-sm" do %>
          <i class="bi bi-plus-lg me-1"></i>New Store
        <% end %>
      </div>
    </div>

    <div class="card-body p-4">
      <% if @stores.any? %>
        <div class="row g-3" id="storeGrid">
          <% @stores.each do |store| %>
            <div class="col-12 col-md-6 col-xl-4 store-card-wrapper">
              <div class="store-card card h-100">
                <!-- Card Header -->
                <div class="store-card-header d-flex align-items-center gap-3">
                  <div class="store-avatar">
                    <i class="bi bi-shop"></i>
                  </div>
                  <div class="flex-grow-1 min-width-0">
                    <div class="d-flex align-items-start justify-content-between gap-2">
                      <h6 class="mb-0 fw-bold text-truncate store-name"><%= store.name %></h6>
                      <% if store.status %>
                        <span class="status-pill bg-success-subtle text-success flex-shrink-0">Active</span>
                      <% else %>
                        <span class="status-pill bg-danger-subtle text-danger flex-shrink-0">Inactive</span>
                      <% end %>
                    </div>
                    <small class="text-muted">Store #<%= store.id.to_s.rjust(3, '0') %></small>
                  </div>
                </div>

                <!-- Card Body -->
                <div class="card-body px-4 py-3">
                  <% if store.address.present? %>
                    <div class="store-info-row">
                      <i class="bi bi-geo-alt-fill"></i>
                      <span class="text-truncate"><%= store.address %></span>
                    </div>
                  <% end %>
                  <% if store.city.present? || store.state.present? %>
                    <div class="store-info-row">
                      <i class="bi bi-pin-map"></i>
                      <span><%= [store.city, store.state, store.pincode].compact.join(', ') %></span>
                    </div>
                  <% end %>
                  <% if store.contact_person.present? %>
                    <div class="store-info-row">
                      <i class="bi bi-person"></i>
                      <span><%= store.contact_person %></span>
                    </div>
                  <% end %>
                  <% if store.contact_mobile.present? %>
                    <div class="store-info-row">
                      <i class="bi bi-telephone"></i>
                      <span><%= store.contact_mobile %></span>
                    </div>
                  <% end %>
                  <% if store.email.present? %>
                    <div class="store-info-row">
                      <i class="bi bi-envelope"></i>
                      <span class="text-truncate"><%= store.email %></span>
                    </div>
                  <% end %>

                  <!-- Bookings count -->
                  <div class="d-flex align-items-center gap-1 mt-2 pt-2 border-top">
                    <i class="bi bi-bag-check text-muted" style="font-size:0.85rem;"></i>
                    <small class="text-muted"><%= store.bookings.count %> bookings</small>
                    <% if store.is_main_inventory %>
                      <span class="badge bg-warning-subtle text-warning ms-auto" style="font-size:0.7rem;">Main Inventory</span>
                    <% end %>
                  </div>
                </div>

                <!-- Card Footer Actions -->
                <div class="card-footer bg-transparent border-top px-4 py-2 d-flex gap-2 flex-wrap">
                  <%= link_to admin_store_path(store), class: "btn btn-sm btn-outline-secondary store-action-btn flex-fill text-center" do %>
                    <i class="bi bi-eye me-1"></i>View
                  <% end %>
                  <%= link_to edit_admin_store_path(store), class: "btn btn-sm btn-outline-primary store-action-btn flex-fill text-center" do %>
                    <i class="bi bi-pencil me-1"></i>Edit
                  <% end %>
                  <%= button_to toggle_status_admin_store_path(store),
                      method: :patch,
                      class: "btn btn-sm store-action-btn #{store.status ? 'btn-outline-danger' : 'btn-outline-success'} flex-fill text-center",
                      form: { style: "display:contents;" } do %>
                    <i class="bi bi-toggle-<%= store.status ? 'off' : 'on' %> me-1"></i>
                    <%= store.status ? 'Disable' : 'Enable' %>
                  <% end %>
                  <%= button_to admin_store_path(store),
                      method: :delete,
                      data: { confirm: "Delete '#{store.name}'? This cannot be undone." },
                      class: "btn btn-sm btn-outline-danger store-action-btn flex-fill text-center",
                      form: { style: "display:contents;" } do %>
                    <i class="bi bi-trash me-1"></i>Delete
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="empty-state">
          <div class="empty-icon-wrap">
            <i class="bi bi-shop-window" style="color:#1C7C54;"></i>
          </div>
          <h4 class="fw-bold mb-2">No Stores Yet</h4>
          <p class="text-muted mb-4" style="max-width:380px; margin: 0 auto 1.5rem;">
            Create your first store to start managing pickup locations and in-store collection for customers.
          </p>
          <%= link_to new_admin_store_path, class: "btn btn-create-store px-5 py-2 fs-6" do %>
            <i class="bi bi-plus-lg me-2"></i>Create Your First Store
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const search = document.getElementById('storeSearch');
  if (!search) return;
  search.addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.store-card-wrapper').forEach(function(wrapper) {
      const text = wrapper.textContent.toLowerCase();
      wrapper.style.display = text.includes(q) ? '' : 'none';
    });
  });
});
</script>
