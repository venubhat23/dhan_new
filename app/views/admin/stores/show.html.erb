<style>
/* Hero banner */
.store-show-hero {
  background: linear-gradient(135deg, #1C7C54 0%, #10b981 100%);
  border-radius: 16px;
  padding: 2rem 2.5rem;
  color: white;
  margin-bottom: 2rem;
  position: relative;
  overflow: hidden;
}
.store-show-hero::after {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 180px; height: 180px;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}
.store-show-hero::before {
  content: '';
  position: absolute;
  bottom: -60px; right: 80px;
  width: 220px; height: 220px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
}
.hero-store-avatar {
  width: 64px; height: 64px;
  background: rgba(255,255,255,0.2);
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem;
  flex-shrink: 0;
}

/* Stat cards */
.stat-card {
  border: none;
  border-radius: 14px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}
.stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
.stat-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
}

/* Info rows */
.info-row {
  display: flex; flex-direction: column;
  padding: 0.85rem 0;
  border-bottom: 1px solid #f3f4f6;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 0.75rem; color: #9ca3af; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 0.25rem; }
.info-value { font-size: 0.9rem; font-weight: 500; color: #111827; }

/* Admin avatar */
.admin-avatar {
  width: 56px; height: 56px;
  background: linear-gradient(135deg, #1C7C54, #10b981);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem; color: white; font-weight: 700;
  flex-shrink: 0;
}

/* Quick action items */
.quick-action-item {
  display: flex; align-items: center;
  padding: 0.85rem 1.25rem;
  border-bottom: 1px solid #f3f4f6;
  color: #374151;
  text-decoration: none;
  transition: background 0.15s;
}
.quick-action-item:hover { background: #f9fafb; color: #111827; }
.quick-action-item:last-child { border-bottom: none; }
.action-icon {
  width: 38px; height: 38px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
  margin-right: 0.85rem;
}

/* Credentials box */
.credentials-box {
  background: #f8fffe;
  border: 1px solid #d1fae5;
  border-radius: 10px;
  padding: 1rem;
}

/* Recent bookings */
.booking-item {
  display: flex; align-items: flex-start;
  padding: 0.75rem 0;
  border-bottom: 1px solid #f3f4f6;
}
.booking-item:last-child { border-bottom: none; }
.booking-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #1C7C54;
  margin-top: 6px; margin-right: 10px; flex-shrink: 0;
}

/* Status toggle btn */
.btn-status-active { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
.btn-status-active:hover { background: #a7f3d0; color: #065f46; }
.btn-status-inactive { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
.btn-status-inactive:hover { background: #fca5a5; color: #991b1b; }
</style>

<!-- Hero Header -->
<div class="store-show-hero">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div class="d-flex align-items-center gap-3">
      <div class="hero-store-avatar">
        <i class="bi bi-shop"></i>
      </div>
      <div>
        <h2 class="fw-bold mb-1" style="font-size:1.7rem;"><%= @store.name %></h2>
        <p class="mb-1 opacity-75" style="font-size:0.9rem;">
          <i class="bi bi-geo-alt me-1"></i><%= @store.full_address.presence || 'Address not set' %>
        </p>
        <% if @store.status %>
          <span class="badge" style="background:rgba(255,255,255,0.25); font-size:0.75rem;">
            <i class="bi bi-check-circle me-1"></i>Active
          </span>
        <% else %>
          <span class="badge bg-danger" style="font-size:0.75rem;">
            <i class="bi bi-x-circle me-1"></i>Inactive
          </span>
        <% end %>
        <% if @store.is_main_inventory %>
          <span class="badge ms-1" style="background:rgba(255,255,255,0.25); font-size:0.75rem;">
            <i class="bi bi-star-fill me-1"></i>Main Inventory
          </span>
        <% end %>
      </div>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap mt-1">
      <%= link_to edit_admin_store_path(@store), class: "btn btn-light btn-sm fw-semibold", style: "border-radius:8px; color:#1C7C54;" do %>
        <i class="bi bi-pencil me-1"></i>Edit Store
      <% end %>
      <%= link_to admin_stores_path, class: "btn btn-sm fw-semibold", style: "border-radius:8px; background:rgba(255,255,255,0.15); color:white; border:1px solid rgba(255,255,255,0.3);" do %>
        <i class="bi bi-arrow-left me-1"></i>All Stores
      <% end %>
    </div>
  </div>
</div>

<!-- Quick Stats Cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card stat-card h-100">
      <div class="card-body p-3 d-flex align-items-center gap-3">
        <div class="stat-icon bg-primary bg-opacity-10">
          <i class="bi bi-calendar-check text-primary"></i>
        </div>
        <div>
          <div class="text-muted small fw-medium">Total Bookings</div>
          <div class="fw-bold fs-4 text-primary"><%= @bookings_count %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card h-100">
      <div class="card-body p-3 d-flex align-items-center gap-3">
        <div class="stat-icon bg-success bg-opacity-10">
          <i class="bi bi-bag-check text-success"></i>
        </div>
        <div>
          <div class="text-muted small fw-medium">This Week</div>
          <div class="fw-bold fs-4 text-success"><%= @store.bookings.where(created_at: 1.week.ago..Time.current).count %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card h-100">
      <div class="card-body p-3 d-flex align-items-center gap-3">
        <div class="stat-icon bg-warning bg-opacity-10">
          <i class="bi bi-clock-history text-warning"></i>
        </div>
        <div>
          <div class="text-muted small fw-medium">Pending</div>
          <div class="fw-bold fs-4 text-warning"><%= @store.bookings.where(status: 'pending').count %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card h-100">
      <div class="card-body p-3 d-flex align-items-center gap-3">
        <div class="stat-icon" style="background:rgba(28,124,84,0.1);">
          <i class="bi bi-person-badge" style="color:#1C7C54;"></i>
        </div>
        <div>
          <div class="text-muted small fw-medium">Store Admin</div>
          <div class="fw-bold" style="color:#1C7C54; font-size:0.9rem; margin-top:2px;">
            <% if @store.has_store_admin? %>
              <i class="bi bi-check-circle-fill me-1"></i>Assigned
            <% else %>
              <span class="text-danger"><i class="bi bi-x-circle me-1"></i>None</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="row g-4">
  <!-- Left Column -->
  <div class="col-lg-8">

    <!-- Store Information -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
      <div class="card-header bg-white py-3 px-4" style="border-radius:14px 14px 0 0;">
        <h5 class="mb-0 fw-semibold">
          <i class="bi bi-info-circle me-2" style="color:#1C7C54;"></i>Store Information
        </h5>
      </div>
      <div class="card-body px-4 py-2">
        <div class="row">
          <div class="col-md-6">
            <div class="info-row">
              <span class="info-label">Store Name</span>
              <span class="info-value"><%= @store.name %></span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="info-row">
              <span class="info-label">Status</span>
              <span class="info-value">
                <% if @store.status %>
                  <span class="badge bg-success-subtle text-success px-2 py-1">Active</span>
                <% else %>
                  <span class="badge bg-danger-subtle text-danger px-2 py-1">Inactive</span>
                <% end %>
              </span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="info-row">
              <span class="info-label">Contact Person</span>
              <span class="info-value"><%= @store.contact_person.presence || '—' %></span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="info-row">
              <span class="info-label">Mobile Number</span>
              <span class="info-value">
                <% if @store.contact_mobile.present? %>
                  <i class="bi bi-phone me-1 text-muted"></i><%= @store.contact_mobile %>
                <% else %>—<% end %>
              </span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="info-row">
              <span class="info-label">Email Address</span>
              <span class="info-value">
                <% if @store.email.present? %>
                  <i class="bi bi-envelope me-1 text-muted"></i><%= @store.email %>
                <% else %><span class="text-muted">Not provided</span><% end %>
              </span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="info-row">
              <span class="info-label">GST Number</span>
              <span class="info-value"><%= @store.gst_no.presence || '—' %></span>
            </div>
          </div>
          <div class="col-12">
            <div class="info-row">
              <span class="info-label">Full Address</span>
              <span class="info-value">
                <% if @store.full_address.present? %>
                  <i class="bi bi-geo-alt me-1 text-muted"></i><%= @store.full_address %>
                <% else %><span class="text-muted">Not provided</span><% end %>
              </span>
            </div>
          </div>
          <% if @store.description.present? %>
          <div class="col-12">
            <div class="info-row">
              <span class="info-label">Description</span>
              <span class="info-value"><%= @store.description %></span>
            </div>
          </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Store Administrator -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
      <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center" style="border-radius:14px 14px 0 0;">
        <h5 class="mb-0 fw-semibold">
          <i class="bi bi-person-badge me-2" style="color:#1C7C54;"></i>Store Administrator
        </h5>
        <%= link_to assign_admin_admin_store_path(@store), class: "btn btn-sm fw-medium", style: "border-radius:8px; background:rgba(28,124,84,0.1); color:#1C7C54; border:none;" do %>
          <i class="bi bi-person-<%= @store.has_store_admin? ? 'gear' : 'plus' %> me-1"></i>
          <%= @store.has_store_admin? ? 'Update Admin' : 'Assign Admin' %>
        <% end %>
      </div>
      <div class="card-body px-4 py-3">
        <% if @store.has_store_admin? %>
          <% admin = @store.store_admin_user %>
          <div class="d-flex align-items-center gap-3 mb-4">
            <div class="admin-avatar">
              <%= admin.first_name.first.upcase rescue '?' %>
            </div>
            <div>
              <h6 class="mb-0 fw-bold"><%= admin.first_name %> <%= admin.last_name %></h6>
              <small class="text-muted"><%= admin.email %></small><br>
              <small class="text-muted"><i class="bi bi-phone me-1"></i><%= admin.mobile %></small>
            </div>
            <div class="ms-auto">
              <span class="badge <%= admin.status ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' %> px-3 py-2">
                <%= admin.status ? 'Active' : 'Inactive' %>
              </span>
            </div>
          </div>
          <div class="credentials-box">
            <div class="d-flex align-items-center mb-2">
              <i class="bi bi-key me-2" style="color:#1C7C54;"></i>
              <span class="fw-semibold" style="color:#1C7C54; font-size:0.9rem;">Login Credentials</span>
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <div class="info-label">Email / Username</div>
                <div class="info-value" style="font-family:monospace;"><%= admin.email %></div>
              </div>
              <div class="col-md-6">
                <div class="info-label">Password</div>
                <div class="info-value" style="font-family:monospace;">
                  <% if @store.admin_plain_password.present? %>
                    <span class="badge bg-warning-subtle text-warning px-2 py-1"><%= @store.admin_plain_password %></span>
                    <small class="text-muted d-block mt-1">Save this password</small>
                  <% else %>
                    <span class="text-muted">••••••••</span>
                    <small class="text-muted d-block mt-1">Not saved (pre-update)</small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-3">
            <%= link_to view_as_store_admin_admin_store_path(@store), class: "btn btn-sm btn-outline-info" do %>
              <i class="bi bi-eye me-1"></i>View Store Dashboard
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-5">
            <div style="width:72px; height:72px; background:rgba(28,124,84,0.08); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; font-size:2rem;">
              <i class="bi bi-person-x" style="color:#1C7C54;"></i>
            </div>
            <h6 class="fw-semibold mb-1">No Admin Assigned</h6>
            <p class="text-muted small mb-3">Assign a store admin so the store owner can log in and manage bookings.</p>
            <%= link_to assign_admin_admin_store_path(@store), class: "btn btn-sm", style: "background:linear-gradient(135deg,#1C7C54,#10b981); color:white; border-radius:8px; padding:0.5rem 1.5rem;" do %>
              <i class="bi bi-person-plus me-1"></i>Assign Admin
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Bookings -->
    <% recent_bookings = @store.bookings.order(created_at: :desc).limit(5) %>
    <div class="card border-0 shadow-sm" style="border-radius:14px;">
      <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center" style="border-radius:14px 14px 0 0;">
        <h5 class="mb-0 fw-semibold">
          <i class="bi bi-activity me-2" style="color:#1C7C54;"></i>Recent Bookings
        </h5>
        <%= link_to admin_bookings_path(store_id: @store.id), class: "btn btn-sm btn-outline-secondary", style: "border-radius:8px; font-size:0.8rem;" do %>
          View All
        <% end %>
      </div>
      <div class="card-body px-4 py-2">
        <% if recent_bookings.any? %>
          <% recent_bookings.each do |booking| %>
            <div class="booking-item">
              <div class="booking-dot"></div>
              <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <span class="fw-semibold small"><%= booking.booking_number %></span>
                    <span class="text-muted small ms-2"><%= booking.customer_name %></span>
                  </div>
                  <span class="badge <%= booking.status == 'confirmed' ? 'bg-success-subtle text-success' : booking.status == 'pending' ? 'bg-warning-subtle text-warning' : 'bg-secondary-subtle text-secondary' %>" style="font-size:0.7rem;">
                    <%= booking.status&.capitalize %>
                  </span>
                </div>
                <small class="text-muted"><%= time_ago_in_words(booking.created_at) %> ago &bull; ₹<%= number_with_precision(booking.total_amount, precision: 0, delimiter: ',') %></small>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-4">
            <i class="bi bi-clock-history text-muted" style="font-size:2rem;"></i>
            <p class="text-muted mt-2 mb-0 small">No bookings yet</p>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <!-- Right Sidebar -->
  <div class="col-lg-4">

    <!-- Quick Actions -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px; overflow:hidden;">
      <div class="card-header bg-white py-3 px-4">
        <h5 class="mb-0 fw-semibold">
          <i class="bi bi-lightning me-2" style="color:#1C7C54;"></i>Quick Actions
        </h5>
      </div>
      <div class="p-0">
        <%= link_to admin_bookings_path(store_id: @store.id), class: "quick-action-item" do %>
          <div class="action-icon" style="background:rgba(99,102,241,0.1);">
            <i class="bi bi-calendar-check" style="color:#6366f1;"></i>
          </div>
          <div>
            <div class="fw-semibold small">View Bookings</div>
            <div class="text-muted" style="font-size:0.78rem;">See all store bookings</div>
          </div>
          <i class="bi bi-chevron-right text-muted ms-auto" style="font-size:0.8rem;"></i>
        <% end %>

        <%= link_to edit_admin_store_path(@store), class: "quick-action-item" do %>
          <div class="action-icon" style="background:rgba(28,124,84,0.1);">
            <i class="bi bi-pencil-square" style="color:#1C7C54;"></i>
          </div>
          <div>
            <div class="fw-semibold small">Edit Store</div>
            <div class="text-muted" style="font-size:0.78rem;">Update store details</div>
          </div>
          <i class="bi bi-chevron-right text-muted ms-auto" style="font-size:0.8rem;"></i>
        <% end %>

        <%= link_to assign_admin_admin_store_path(@store), class: "quick-action-item" do %>
          <div class="action-icon" style="background:rgba(245,158,11,0.1);">
            <i class="bi bi-person-gear" style="color:#f59e0b;"></i>
          </div>
          <div>
            <div class="fw-semibold small"><%= @store.has_store_admin? ? 'Update Admin' : 'Assign Admin' %></div>
            <div class="text-muted" style="font-size:0.78rem;">Manage store administrator</div>
          </div>
          <i class="bi bi-chevron-right text-muted ms-auto" style="font-size:0.8rem;"></i>
        <% end %>

        <% if @store.has_store_admin? %>
          <%= link_to view_as_store_admin_admin_store_path(@store), class: "quick-action-item" do %>
            <div class="action-icon" style="background:rgba(14,165,233,0.1);">
              <i class="bi bi-eye" style="color:#0ea5e9;"></i>
            </div>
            <div>
              <div class="fw-semibold small">View as Store Admin</div>
              <div class="text-muted" style="font-size:0.78rem;">Preview store dashboard</div>
            </div>
            <i class="bi bi-chevron-right text-muted ms-auto" style="font-size:0.8rem;"></i>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Store Settings -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
      <div class="card-header bg-white py-3 px-4">
        <h5 class="mb-0 fw-semibold">
          <i class="bi bi-gear me-2" style="color:#1C7C54;"></i>Store Settings
        </h5>
      </div>
      <div class="card-body px-4 py-3">
        <!-- Status -->
        <div class="d-flex justify-content-between align-items-center mb-3 pb-3" style="border-bottom:1px solid #f3f4f6;">
          <div>
            <div class="fw-semibold small">Store Status</div>
            <small class="text-muted">Toggle store availability</small>
          </div>
          <%= link_to toggle_status_admin_store_path(@store),
              data: { turbo_method: :patch },
              class: "btn btn-sm #{@store.status ? 'btn-status-active' : 'btn-status-inactive'}",
              style: "border-radius:8px; font-size:0.8rem;" do %>
            <% if @store.status %>
              <i class="bi bi-check-circle-fill me-1"></i>Active
            <% else %>
              <i class="bi bi-x-circle-fill me-1"></i>Inactive
            <% end %>
          <% end %>
        </div>

        <!-- Main Inventory -->
        <div class="d-flex justify-content-between align-items-center mb-3 pb-3" style="border-bottom:1px solid #f3f4f6;">
          <div>
            <div class="fw-semibold small">Main Inventory</div>
            <small class="text-muted">Central stock location</small>
          </div>
          <span class="badge <%= @store.is_main_inventory ? 'bg-warning-subtle text-warning' : 'bg-secondary-subtle text-secondary' %> px-2 py-1">
            <%= @store.is_main_inventory ? 'Yes' : 'No' %>
          </span>
        </div>

        <!-- Store ID -->
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="fw-semibold small">Store ID</div>
            <small class="text-muted">Internal identifier</small>
          </div>
          <span class="badge bg-light text-dark border px-2 py-1" style="font-family:monospace;">
            #<%= @store.id.to_s.rjust(3, '0') %>
          </span>
        </div>

        <hr class="my-3">
        <div class="d-grid">
          <%= link_to edit_admin_store_path(@store), class: "btn btn-sm fw-medium", style: "border-radius:8px; background:linear-gradient(135deg,#1C7C54,#10b981); color:white;" do %>
            <i class="bi bi-pencil me-1"></i>Edit Store Details
          <% end %>
        </div>

        <% if @store.can_be_deleted? %>
          <div class="d-grid mt-2">
            <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius:8px;"
                    data-bs-toggle="modal" data-bs-target="#deleteStoreModal">
              <i class="bi bi-trash me-1"></i>Delete Store
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Store Meta -->
    <div class="card border-0 shadow-sm" style="border-radius:14px;">
      <div class="card-body px-4 py-3">
        <div class="info-row">
          <span class="info-label">Created</span>
          <span class="info-value small"><%= @store.created_at.strftime('%d %b %Y, %I:%M %p') %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Last Updated</span>
          <span class="info-value small"><%= @store.updated_at.strftime('%d %b %Y, %I:%M %p') %></span>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Delete Store Modal -->
<% if @store.can_be_deleted? %>
<div class="modal fade" id="deleteStoreModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0" style="border-radius:16px;">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title text-danger fw-bold">
          <i class="bi bi-exclamation-triangle me-2"></i>Delete Store
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to permanently delete <strong><%= @store.name %></strong>?</p>
        <p class="text-muted small mb-0">This action cannot be undone.</p>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal" style="border-radius:8px;">Cancel</button>
        <%= link_to admin_store_path(@store),
            data: { turbo_method: :delete, turbo_confirm: "Are you sure? This cannot be undone." },
            class: "btn btn-danger btn-sm",
            style: "border-radius:8px;" do %>
          <i class="bi bi-trash me-1"></i>Delete Store
        <% end %>
      </div>
    </div>
  </div>
</div>
<% end %>
