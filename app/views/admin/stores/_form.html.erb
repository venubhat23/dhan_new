<%= form_with(model: [:admin, store], local: true) do |form| %>
  <% if store.errors.any? %>
    <div class="alert alert-danger alert-dismissible" role="alert">
      <h6 class="alert-heading mb-1">Please fix the following errors:</h6>
      <ul class="mb-0">
        <% store.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <div class="row mb-3">
    <div class="col-md-6">
      <label class="form-label">Store Name <span class="text-danger">*</span></label>
      <%= form.text_field :name, class: "form-control", placeholder: "Enter store name", required: true %>
    </div>
    <div class="col-md-6">
      <label class="form-label">Contact Person <span class="text-danger">*</span></label>
      <%= form.text_field :contact_person, class: "form-control", placeholder: "Enter contact person name", required: true %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-6">
      <label class="form-label">Contact Mobile <span class="text-danger">*</span></label>
      <%= form.text_field :contact_mobile, class: "form-control", placeholder: "Enter 10-digit mobile number", required: true %>
    </div>
    <div class="col-md-6">
      <label class="form-label">Status</label>
      <div class="form-check form-switch mt-2">
        <%= form.check_box :status, class: "form-check-input", checked: store.new_record? ? true : store.status %>
        <label class="form-check-label">Active</label>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label">Address</label>
    <%= form.text_area :address, class: "form-control", rows: 3, placeholder: "Enter complete address" %>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <label class="form-label">City <span class="text-danger">*</span></label>
      <%= form.text_field :city, class: "form-control", placeholder: "Enter city", required: true %>
    </div>
    <div class="col-md-4">
      <label class="form-label">State <span class="text-danger">*</span></label>
      <%= form.text_field :state, class: "form-control", placeholder: "Enter state", required: true %>
    </div>
    <div class="col-md-4">
      <label class="form-label">Pincode <span class="text-danger">*</span></label>
      <%= form.text_field :pincode, class: "form-control", placeholder: "6-digit pincode", required: true %>
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label">Description</label>
    <%= form.text_area :description, class: "form-control", rows: 3, placeholder: "Enter store description (optional)" %>
  </div>

  <% if store.new_record? %>
    <hr class="my-4">
    <h6 class="mb-3 fw-bold"><i class="bi bi-person-badge me-2"></i>Store Admin Login (Optional)</h6>
    <p class="text-muted small mb-3">Create a separate login account for the store owner/manager. They will only see and manage this store.</p>

    <div class="mb-3">
      <div class="form-check">
        <input type="checkbox" class="form-check-input" id="create_admin_user_check" name="store[create_admin_user]" value="1"
               onchange="document.getElementById('admin-fields').style.display = this.checked ? 'block' : 'none'">
        <label class="form-check-label" for="create_admin_user_check">Create store admin login</label>
      </div>
    </div>

    <div id="admin-fields" style="display: none;" class="border rounded p-3 bg-light">
      <div class="mb-3">
        <button type="button" class="btn btn-outline-primary btn-sm" onclick="autoGenerateAdminCredentials()">
          <i class="bi bi-magic me-1"></i> Auto-generate Credentials
        </button>
        <span class="text-muted small ms-2">Fill all fields automatically with system-generated values</span>
      </div>
      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">First Name</label>
          <input type="text" id="admin_first_name" name="store[admin_first_name]" class="form-control" placeholder="Admin first name">
        </div>
        <div class="col-md-6">
          <label class="form-label">Last Name</label>
          <input type="text" id="admin_last_name" name="store[admin_last_name]" class="form-control" placeholder="Admin last name">
        </div>
      </div>
      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">Email</label>
          <input type="email" id="admin_email" name="store[admin_email]" class="form-control" placeholder="admin@store.com">
        </div>
        <div class="col-md-6">
          <label class="form-label">Mobile</label>
          <input type="text" id="admin_mobile" name="store[admin_mobile]" class="form-control" placeholder="10-digit mobile">
        </div>
      </div>
      <div class="row">
        <div class="col-md-6">
          <label class="form-label">Password</label>
          <input type="text" id="admin_password" name="store[admin_password]" class="form-control" placeholder="Min 6 characters">
          <div class="form-text text-muted">Note the password — it will be shown once after creation.</div>
        </div>
      </div>
    </div>

    <script>
      function autoGenerateAdminCredentials() {
        var firstNames = ['Amit', 'Rahul', 'Suresh', 'Vikram', 'Ravi', 'Anand', 'Kiran', 'Deepak'];
        var lastNames  = ['Kumar', 'Sharma', 'Verma', 'Singh', 'Patel', 'Nair', 'Reddy', 'Joshi'];
        var rand = function(arr) { return arr[Math.floor(Math.random() * arr.length)]; };

        var first    = rand(firstNames);
        var last     = rand(lastNames);
        var num      = Math.floor(1000 + Math.random() * 9000);
        var storeName = (document.querySelector('[name="store[name]"]').value || 'store')
                          .toLowerCase().replace(/\s+/g, '');
        var email    = 'admin.' + storeName + num + '@store.local';
        var prefixes = ['7', '8', '9'];
        var mobile   = rand(prefixes) + String(Math.floor(100000000 + Math.random() * 900000000));
        var chars    = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
        var password = '';
        for (var i = 0; i < 8; i++) password += chars[Math.floor(Math.random() * chars.length)];

        document.getElementById('admin_first_name').value = first;
        document.getElementById('admin_last_name').value  = last;
        document.getElementById('admin_email').value      = email;
        document.getElementById('admin_mobile').value     = mobile;
        document.getElementById('admin_password').value   = password;
      }
    </script>
  <% end %>

  <div class="row mb-3">
    <div class="col-md-6">
      <label class="form-label">Commission Percentage (%)</label>
      <%= form.number_field :commission_percentage, class: "form-control", placeholder: "e.g. 10", min: 0, max: 100, step: 0.01, value: store.commission_percentage.to_f %>
      <div class="form-text">Revenue share paid to this store (used in Commission Report).</div>
    </div>
  </div>

  <div class="pt-4">
    <%= form.submit store.new_record? ? "Create Store" : "Update Store", class: "btn btn-primary me-2" %>
    <%= link_to "Cancel", admin_stores_path, class: "btn btn-label-secondary" %>
  </div>
<% end %>