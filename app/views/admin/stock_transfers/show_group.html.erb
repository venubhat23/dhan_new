<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold"><i class="bi bi-arrow-left-right me-2"></i><%= @from_store %> &rarr; <%= @to_store %></h4>
    <small class="text-muted">
      Requested by <strong><%= @requested_by&.first_name %> <%= @requested_by&.last_name %></strong>
      on <%= @created_at.strftime('%d %b %Y, %I:%M %p') %>
    </small>
  </div>
  <%= link_to admin_stock_transfers_path, class: "btn btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-1"></i>Back to all requests
  <% end %>
</div>

<% if @notes.present? %>
  <div class="text-muted small mb-3"><i class="bi bi-chat me-1"></i><%= @notes %></div>
<% end %>

<% if @status == 'pending' %>
  <div class="d-flex gap-2 mb-3">
    <form action="<%= approve_group_admin_stock_transfers_path %>" method="post"
          data-turbo="false" data-bulk-form data-verb="Approve"
          data-bulk-progress-url="<%= bulk_progress_admin_stock_transfers_path %>">
      <%= hidden_field_tag :_method, 'patch' %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <%= hidden_field_tag :group_id, @group_id %>
      <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Approve all products in this request?')">
        <i class="bi bi-check2-all me-1"></i>Approve All
      </button>
    </form>
    <button type="button" class="btn btn-outline-danger btn-sm" onclick="toggleGroupReject()">
      <i class="bi bi-x-circle me-1"></i>Reject All
    </button>
  </div>

  <div id="group_reject" style="display:none;" class="px-3 py-2 bg-danger-subtle mb-3 rounded">
    <form action="<%= reject_group_admin_stock_transfers_path %>" method="post" class="d-flex gap-2 align-items-center"
          data-turbo="false" data-bulk-form data-verb="Reject"
          data-bulk-progress-url="<%= bulk_progress_admin_stock_transfers_path %>">
      <%= hidden_field_tag :_method, 'patch' %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <%= hidden_field_tag :group_id, @group_id %>
      <input type="text" name="rejection_reason" placeholder="Rejection reason (optional)" class="form-control form-control-sm" style="max-width:300px;">
      <button type="submit" class="btn btn-danger btn-sm">Confirm Reject All</button>
      <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleGroupReject()">Cancel</button>
    </form>
  </div>
<% end %>

<div class="card border-0 shadow-sm" style="border-radius:14px;">
  <div class="card-body p-0">
    <table class="table table-hover mb-0" style="font-size:0.85rem;">
      <thead style="background:#fafbfc; font-size:0.78rem;">
        <tr>
          <th class="px-4 py-2">Product</th>
          <th class="py-2">Requested</th>
          <th class="py-2">Available</th>
          <th class="py-2">Status</th>
          <th class="py-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @transfers.each do |t| %>
          <% avail = @stock_cache[[t.product_id, t.from_store_id]].to_f %>
          <tr class="<%= avail < t.quantity && t.status == 'pending' ? 'table-danger' : '' %>">
            <td class="px-4 py-2">
              <strong><%= t.product&.name %></strong>
              <% if t.product_variant %>
                <span class="badge bg-primary-subtle text-primary ms-1" style="font-size:0.7rem;"><%= t.product_variant.label %></span>
              <% end %>
            </td>
            <td class="py-2 fw-semibold"><%= t.quantity %></td>
            <td class="py-2">
              <% if t.status == 'pending' %>
                <% if avail > 0 %>
                  <span class="text-success fw-semibold"><%= avail.to_i %></span>
                  <% if avail < t.quantity %>
                    <span class="badge bg-danger ms-1" style="font-size:0.68rem;">Low</span>
                  <% end %>
                <% else %>
                  <span class="text-danger fw-semibold">0</span>
                  <span class="badge bg-danger ms-1" style="font-size:0.68rem;">No stock</span>
                <% end %>
              <% else %>
                <span class="text-muted">&mdash;</span>
              <% end %>
            </td>
            <td class="py-2">
              <% case t.status
                 when 'pending' %>
                <span class="badge bg-warning-subtle text-warning">Pending</span>
              <% when 'completed' %>
                <span class="badge bg-success-subtle text-success">Completed</span>
              <% when 'rejected' %>
                <span class="badge bg-danger-subtle text-danger">Rejected</span>
              <% else %>
                <span class="badge bg-secondary-subtle text-secondary"><%= t.status&.capitalize %></span>
              <% end %>
              <% if t.rejection_reason.present? %>
                <div class="text-muted" style="font-size:0.72rem;"><%= t.rejection_reason %></div>
              <% end %>
            </td>
            <td class="py-2">
              <% if t.status == 'pending' %>
                <div class="d-flex gap-1">
                  <%= button_to approve_admin_stock_transfer_path(t), method: :patch,
                      form: { data: { turbo_confirm: "Approve #{t.quantity} × #{t.product&.name}?" } },
                      class: "btn btn-sm btn-outline-success", style: "border-radius:6px; font-size:0.75rem;" do %>
                      <i class="bi bi-check-lg"></i> Approve
                    <% end %>
                  <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius:6px; font-size:0.75rem;"
                          onclick="rejectTransfer(<%= t.id %>)">
                    <i class="bi bi-x-lg"></i> Reject
                  </button>
                </div>
                <form id="reject_form_<%= t.id %>" action="<%= reject_admin_stock_transfer_path(t) %>" method="post" style="display:none; margin-top:0.4rem;">
                  <%= hidden_field_tag :_method, 'patch' %>
                  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                  <input type="text" name="rejection_reason" placeholder="Reason (optional)" class="form-control form-control-sm mb-1">
                  <button type="submit" class="btn btn-danger btn-sm" style="border-radius:6px; font-size:0.75rem;">Confirm Reject</button>
                </form>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @transfers %>
</div>

<script>
function rejectTransfer(id) {
  const form = document.getElementById('reject_form_' + id);
  form.style.display = form.style.display === 'none' ? 'block' : 'none';
}

function toggleGroupReject() {
  const el = document.getElementById('group_reject');
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>

<%= render 'bulk_progress_modal' %>
