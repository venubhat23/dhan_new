<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1 fw-bold">Edit Staff</h4>
    <small class="text-muted"><%= @staff_member.name %></small>
  </div>
  <%= link_to admin_staff_member_path(@staff_member), class: "btn btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-2"></i>Back
  <% end %>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-pencil me-2"></i>Staff Details</h6>
      </div>
      <div class="card-body">
        <%= render 'form', staff_member: @staff_member %>
      </div>
    </div>
  </div>
</div>
