<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @franchise.display_name %></h2>
    <p class="text-muted mb-0">
      <span class="badge bg-warning me-2">
        <i class="bi bi-shop me-1"></i>
        Franchise Partner
      </span>
      Franchise ID: #<%= @franchise.id %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_franchise_path(@franchise), class: "btn btn-warning" do %>
      <i class="bi bi-pencil me-1"></i>
      Edit Franchise
    <% end %>
    <%= link_to admin_franchises_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Franchises
    <% end %>
  </div>
</div>

<div class="row">
  <!-- Main Franchise Information -->
  <div class="col-lg-8">
    <!-- Basic Information -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
          <i class="bi bi-building me-2 text-warning"></i>
          Basic Information
        </h5>
        <span class="badge bg-<%= @franchise.status? ? 'success' : 'danger' %>">
          <%= @franchise.status? ? 'Active' : 'Inactive' %>
        </span>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <strong class="text-muted d-block">Franchise Name</strong>
            <%= @franchise.name %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Contact Person</strong>
            <%= @franchise.contact_person_name.present? ? @franchise.contact_person_name : '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Business Type</strong>
            <%= @franchise.business_type.present? ? @franchise.business_type.titleize : '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Email</strong>
            <% if @franchise.email.present? %>
              <a href="mailto:<%= @franchise.email %>"><%= @franchise.email %></a>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Mobile</strong>
            <% if @franchise.mobile.present? %>
              <a href="tel:<%= @franchise.mobile %>"><%= @franchise.mobile %></a>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">WhatsApp Number</strong>
            <% if @franchise.whatsapp_number.present? %>
              <div class="d-flex align-items-center">
                <a href="https://wa.me/<%= @franchise.whatsapp_number.gsub(/\D/, '') %>" class="me-2">
                  <%= @franchise.whatsapp_number %>
                </a>
                <% if @franchise.whatsapp_same_as_mobile? %>
                  <span class="badge bg-info-subtle text-info">Same as Mobile</span>
                <% end %>
              </div>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Commission Percentage</strong>
            <% if @franchise.commission_percentage.present? %>
              <span class="badge bg-success-subtle text-success fs-6">
                <%= number_with_precision(@franchise.commission_percentage, precision: 2) %>%
              </span>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Franchise Fee</strong>
            <% if @franchise.franchise_fee.present? %>
              ₹<%= number_with_delimiter(@franchise.franchise_fee) %>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Created At</strong>
            <%= @franchise.created_at&.strftime("%B %d, %Y at %I:%M %p") %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Last Updated</strong>
            <%= @franchise.updated_at&.strftime("%B %d, %Y at %I:%M %p") %>
          </div>
        </div>
      </div>
    </div>

    <!-- Login Credentials -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
          <i class="bi bi-key me-2 text-primary"></i>
          Login Credentials
        </h5>
        <% if @franchise.user.blank? && @franchise.email.present? %>
          <%= form_with url: toggle_status_admin_franchise_path(@franchise), method: :patch, local: true, class: "d-inline" do |f| %>
            <%= f.submit "Create User Account", class: "btn btn-sm btn-success",
                data: { confirm: "Create a user account for this franchise?" } %>
          <% end %>
        <% end %>
      </div>
      <% if @franchise.user %>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <strong class="text-muted d-block">Username (Email)</strong>
            <div class="d-flex align-items-center">
              <span class="me-2"><%= @franchise.user.email %></span>
              <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('<%= @franchise.user.email %>')">
                <i class="bi bi-copy"></i>
              </button>
            </div>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Password</strong>
            <div class="d-flex align-items-center">
              <span class="me-2 font-monospace">
                <% if @franchise.auto_generated_password.present? %>
                  <%= @franchise.auto_generated_password %>
                <% else %>
                  <span class="text-muted">Set by franchise</span>
                <% end %>
              </span>
              <% if @franchise.auto_generated_password.present? %>
                <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('<%= @franchise.auto_generated_password %>')">
                  <i class="bi bi-copy"></i>
                </button>
              <% end %>
            </div>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">User Type</strong>
            <span class="badge bg-warning"><%= @franchise.user.user_type.titleize %></span>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Account Status</strong>
            <span class="badge bg-<%= @franchise.user.status? ? 'success' : 'danger' %>">
              <%= @franchise.user.status? ? 'Active' : 'Inactive' %>
            </span>
          </div>
          <div class="col-12">
            <div class="alert alert-info mb-0 d-flex justify-content-between align-items-center">
              <div>
                <i class="bi bi-info-circle me-2"></i>
                <strong>Login URL:</strong>
                <a href="<%= request.base_url %>/franchise/login" target="_blank" class="alert-link">
                  <%= request.base_url %>/franchise/login
                </a>
              </div>
              <button class="btn btn-sm btn-outline-primary ms-2" onclick="copyToClipboard('<%= request.base_url %>/franchise/login')" title="Copy Login URL">
                <i class="bi bi-copy"></i>
              </button>
            </div>
          </div>
          <% if @franchise.auto_generated_password.present? %>
          <div class="col-12">
            <button class="btn btn-success w-100" onclick="copyAllCredentials('<%= @franchise.user.email %>', '<%= @franchise.auto_generated_password %>', '<%= request.base_url %>/franchise/login')">
              <i class="bi bi-clipboard-check me-2"></i>Copy All Credentials
            </button>
          </div>
          <% end %>
        </div>
      </div>
      <% else %>
      <div class="card-body">
        <div class="alert alert-warning mb-0">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>No User Account:</strong> This franchise doesn't have login credentials yet.
          <% if @franchise.email.present? %>
            User account creation happens automatically during franchise creation.
          <% else %>
            Franchise email is required to create a user account.
          <% end %>
        </div>
      </div>
      <% end %>
    </div>

    <!-- Address & Location -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-geo-alt me-2 text-success"></i>
          Address & Location
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <% if @franchise.address.present? %>
          <div class="col-12">
            <strong class="text-muted d-block">Address</strong>
            <%= @franchise.address %>
          </div>
          <% end %>
          <div class="col-md-6">
            <strong class="text-muted d-block">City</strong>
            <%= @franchise.city.present? ? @franchise.city : '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">State</strong>
            <%= @franchise.state.present? ? @franchise.state : '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Pincode</strong>
            <%= @franchise.pincode.present? ? @franchise.pincode : '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Location</strong>
            <% if @franchise.has_location? %>
              <div class="d-flex flex-column">
                <small>Lat: <%= @franchise.latitude %></small>
                <small>Lng: <%= @franchise.longitude %></small>
                <a href="https://maps.google.com/?q=<%= @franchise.latitude %>,<%= @franchise.longitude %>"
                   target="_blank" class="btn btn-sm btn-outline-primary mt-2">
                  <i class="bi bi-map me-1"></i>View on Map
                </a>
              </div>
            <% else %>
              <span class="text-muted">Location not provided</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Legal & Business Details -->
    <% if @franchise.pan_no.present? || @franchise.gst_no.present? %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-file-text me-2 text-info"></i>
          Legal & Business Details
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <strong class="text-muted d-block">PAN Number</strong>
            <% if @franchise.pan_no.present? %>
              <span class="font-monospace"><%= @franchise.pan_no %></span>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">GST Number</strong>
            <% if @franchise.gst_no.present? %>
              <span class="font-monospace"><%= @franchise.gst_no %></span>
            <% else %>
              -
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <% end %>

    <!-- Franchise Activity -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-graph-up me-2 text-primary"></i>
          Franchise Activity
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <div class="text-center">
              <h4 class="text-primary mb-1"><%= @franchise.bookings.count %></h4>
              <small class="text-muted">Total Bookings</small>
            </div>
          </div>
          <div class="col-md-6">
            <div class="text-center">
              <h4 class="text-success mb-1">
                <% total_revenue = @franchise.bookings.sum(:total_amount) %>
                ₹<%= number_with_delimiter(total_revenue.to_i) %>
              </h4>
              <small class="text-muted">Total Revenue</small>
            </div>
          </div>
        </div>

        <% if @franchise.bookings.any? %>
          <hr>
          <h6 class="mb-3">Recent Bookings</h6>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Booking #</th>
                  <th>Customer</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Amount</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @franchise.bookings.includes(:customer).order(created_at: :desc).limit(5).each do |booking| %>
                  <tr>
                    <td><%= booking.booking_number || "##{booking.id}" %></td>
                    <td><%= booking.customer&.display_name || 'N/A' %></td>
                    <td><%= booking.created_at.strftime("%b %d, %Y") %></td>
                    <td>
                      <span class="badge bg-<%= booking.status == 'completed' ? 'success' : 'warning' %>">
                        <%= booking.status&.titleize || 'Pending' %>
                      </span>
                    </td>
                    <td>₹<%= number_with_delimiter(booking.total_amount.to_i) if booking.total_amount %></td>
                    <td>
                      <%= link_to "View", admin_booking_path(booking), class: "btn btn-sm btn-outline-primary" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="text-center mt-3">
            <%= link_to "View All Franchise Bookings", admin_bookings_path(franchise_id: @franchise.id), class: "btn btn-outline-primary" %>
          </div>
        <% else %>
          <div class="text-center text-muted py-4">
            <i class="bi bi-cart-x fs-1 d-block mb-3"></i>
            <h6>No Bookings Yet</h6>
            <p class="mb-0">This franchise hasn't received any bookings yet.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Additional Notes -->
    <% if @franchise.notes.present? %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-journal-text me-2 text-info"></i>
          Additional Notes
        </h5>
      </div>
      <div class="card-body">
        <div class="p-3 bg-light rounded">
          <%= simple_format(@franchise.notes) %>
        </div>
      </div>
    </div>
    <% end %>
  </div>

  <!-- Sidebar -->
  <div class="col-lg-4">
    <!-- Quick Stats -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">
          <i class="bi bi-speedometer2 me-1 text-primary"></i>
          Quick Stats
        </h6>
      </div>
      <div class="card-body">
        <div class="row g-2 text-center">
          <div class="col-12">
            <small class="text-muted d-block">Partner Since</small>
            <strong><%= @franchise.created_at.strftime("%B %Y") %></strong>
          </div>
          <hr>
          <div class="col-6">
            <small class="text-muted d-block">Total Bookings</small>
            <h5 class="text-primary mb-0"><%= @franchise.bookings.count %></h5>
          </div>
          <div class="col-6">
            <small class="text-muted d-block">Revenue</small>
            <h5 class="text-success mb-0">₹<%= number_with_delimiter(@franchise.bookings.sum(:total_amount).to_i) %></h5>
          </div>
          <hr class="col-12">
          <div class="col-6">
            <small class="text-muted d-block">Commission Rate</small>
            <h6 class="text-warning mb-0">
              <%= @franchise.commission_percentage.present? ? "#{number_with_precision(@franchise.commission_percentage, precision: 2)}%" : 'Not Set' %>
            </h6>
          </div>
          <div class="col-6">
            <small class="text-muted d-block">Status</small>
            <h6 class="mb-0">
              <span class="badge bg-<%= @franchise.status? ? 'success' : 'danger' %>">
                <%= @franchise.status? ? 'Active' : 'Inactive' %>
              </span>
            </h6>
          </div>
        </div>
      </div>
    </div>

    <!-- Franchise Timeline -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">
          <i class="bi bi-clock-history me-1 text-info"></i>
          Franchise Timeline
        </h6>
      </div>
      <div class="card-body">
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-marker bg-success"></div>
            <div class="timeline-content">
              <small class="text-muted">Franchise Created</small>
              <div><%= @franchise.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
            </div>
          </div>
          <% if @franchise.user %>
            <div class="timeline-item">
              <div class="timeline-marker bg-info"></div>
              <div class="timeline-content">
                <small class="text-muted">User Account Created</small>
                <div><%= @franchise.user.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
              </div>
            </div>
          <% end %>
          <% if @franchise.updated_at != @franchise.created_at %>
            <div class="timeline-item">
              <div class="timeline-marker bg-warning"></div>
              <div class="timeline-content">
                <small class="text-muted">Last Updated</small>
                <div><%= @franchise.updated_at.strftime("%B %d, %Y at %I:%M %p") %></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Location Card -->
    <% if @franchise.has_location? %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">
          <i class="bi bi-geo-alt me-1 text-success"></i>
          Location
        </h6>
      </div>
      <div class="card-body text-center">
        <div class="mb-3">
          <small class="text-muted d-block">GPS Coordinates</small>
          <div class="font-monospace small">
            <%= @franchise.latitude %>, <%= @franchise.longitude %>
          </div>
        </div>
        <a href="https://maps.google.com/?q=<%= @franchise.latitude %>,<%= @franchise.longitude %>"
           target="_blank" class="btn btn-success btn-sm">
          <i class="bi bi-map me-1"></i>
          Open in Google Maps
        </a>
      </div>
    </div>
    <% end %>

    <!-- Actions -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">
          <i class="bi bi-gear me-1 text-secondary"></i>
          Quick Actions
        </h6>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <%= link_to edit_admin_franchise_path(@franchise), class: "btn btn-warning" do %>
            <i class="bi bi-pencil me-2"></i>Edit Franchise
          <% end %>
          <%= link_to toggle_status_admin_franchise_path(@franchise),
              method: :patch,
              class: "btn btn-#{@franchise.status? ? 'danger' : 'success'}",
              data: { confirm: "Are you sure you want to #{@franchise.status? ? 'deactivate' : 'activate'} this franchise?" } do %>
            <i class="bi bi-power me-2"></i>
            <%= @franchise.status? ? 'Deactivate' : 'Activate' %> Franchise
          <% end %>
          <% if @franchise.email.present? %>
            <a href="mailto:<%= @franchise.email %>" class="btn btn-outline-primary">
              <i class="bi bi-envelope me-2"></i>Send Email
            </a>
          <% end %>
          <% if @franchise.mobile.present? %>
            <a href="tel:<%= @franchise.mobile %>" class="btn btn-outline-success">
              <i class="bi bi-telephone me-2"></i>Call Franchise
            </a>
          <% end %>
          <% if @franchise.whatsapp_number.present? %>
            <a href="https://wa.me/<%= @franchise.whatsapp_number.gsub(/\D/, '') %>"
               target="_blank" class="btn btn-outline-info">
              <i class="bi bi-whatsapp me-2"></i>WhatsApp
            </a>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.timeline {
  position: relative;
  padding-left: 20px;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 8px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: #dee2e6;
}

.timeline-item {
  position: relative;
  margin-bottom: 1rem;
}

.timeline-marker {
  position: absolute;
  left: -15px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid #fff;
}

.timeline-content {
  padding-left: 10px;
}

.font-monospace {
  font-family: 'Courier New', monospace;
}
</style>

<script>
function copyAllCredentials(email, password, loginUrl) {
  const text = `Login URL: ${loginUrl}\nUsername: ${email}\nPassword: ${password}`;
  copyToClipboard(text);
}

function copyToClipboard(text) {
  if (navigator.clipboard && window.isSecureContext) {
    // Use modern clipboard API
    navigator.clipboard.writeText(text).then(() => {
      showCopySuccess();
    }).catch(err => {
      console.error('Failed to copy: ', err);
      fallbackCopyTextToClipboard(text);
    });
  } else {
    // Fallback for older browsers
    fallbackCopyTextToClipboard(text);
  }
}

function fallbackCopyTextToClipboard(text) {
  const textArea = document.createElement("textarea");
  textArea.value = text;
  textArea.style.top = "0";
  textArea.style.left = "0";
  textArea.style.position = "fixed";
  document.body.appendChild(textArea);
  textArea.focus();
  textArea.select();

  try {
    const successful = document.execCommand('copy');
    if (successful) {
      showCopySuccess();
    } else {
      console.error('Fallback: Copying text command was unsuccessful');
    }
  } catch (err) {
    console.error('Fallback: Oops, unable to copy', err);
  }

  document.body.removeChild(textArea);
}

function showCopySuccess() {
  // Create a temporary success message
  const message = document.createElement('div');
  message.className = 'alert alert-success position-fixed top-0 end-0 m-3';
  message.style.zIndex = '9999';
  message.innerHTML = '<i class="bi bi-check-circle me-2"></i>Copied to clipboard!';
  document.body.appendChild(message);

  // Remove the message after 2 seconds
  setTimeout(() => {
    if (document.body.contains(message)) {
      document.body.removeChild(message);
    }
  }, 2000);
}
</script>