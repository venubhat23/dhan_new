<% content_for :title, "Edit Delivery Charge - #{@delivery_charge.pincode}" %>

<div class="container-fluid">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

      <div class="d-flex align-items-center mb-4 gap-3">
        <%= link_to admin_delivery_settings_path, class: "btn btn-outline-secondary btn-sm" do %>
          <i class="fas fa-arrow-left me-1"></i> Back to Delivery Settings
        <% end %>
        <h4 class="mb-0"><i class="fas fa-truck me-2"></i>Edit Delivery Charge</h4>
      </div>

      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">Pincode: <strong><%= @delivery_charge.pincode %></strong></h5>
        </div>
        <div class="card-body p-4">

          <% if flash[:alert] %>
            <div class="alert alert-danger"><%= flash[:alert] %></div>
          <% end %>

          <%= form_with url: admin_delivery_setting_path(@delivery_charge), method: :patch, local: true do |f| %>

            <div class="mb-3">
              <label class="form-label fw-semibold">Pincode</label>
              <input type="text" class="form-control bg-light" value="<%= @delivery_charge.pincode %>" readonly>
              <div class="form-text">Pincode cannot be changed after creation.</div>
            </div>

            <div class="mb-3">
              <label for="delivery_charge_area" class="form-label fw-semibold">Area</label>
              <%= f.text_field :area, class: "form-control", placeholder: "e.g., MG Road, Bangalore Central", id: "delivery_charge_area" %>
            </div>

            <div class="mb-3">
              <label for="delivery_charge_charge_amount" class="form-label fw-semibold">
                Charge Amount (₹) <span class="text-danger">*</span>
              </label>
              <%= f.number_field :charge_amount, class: "form-control", min: 0, step: 0.01, required: true, id: "delivery_charge_charge_amount" %>
            </div>

            <div class="mb-4">
              <div class="form-check form-switch">
                <%= f.check_box :is_active, class: "form-check-input", id: "delivery_charge_is_active", role: "switch" %>
                <label class="form-check-label fw-semibold" for="delivery_charge_is_active">Active</label>
              </div>
              <div class="form-text">Inactive zones are hidden from customers.</div>
            </div>

            <div class="d-flex gap-2">
              <%= f.submit "Update Delivery Charge", class: "btn btn-primary px-4" %>
              <%= link_to "Cancel", admin_delivery_settings_path, class: "btn btn-outline-secondary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
