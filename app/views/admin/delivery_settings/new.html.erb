<% content_for :title, "Add New Pincode" %>

<div class="container-fluid">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

      <div class="d-flex align-items-center mb-4 gap-3">
        <%= link_to admin_delivery_settings_path, class: "btn btn-outline-secondary btn-sm" do %>
          <i class="fas fa-arrow-left me-1"></i> Back to Delivery Settings
        <% end %>
        <h4 class="mb-0"><i class="fas fa-truck me-2"></i>Add New Pincode</h4>
      </div>

      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">New Delivery Charge</h5>
        </div>
        <div class="card-body p-4">

          <% if @delivery_charge.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% @delivery_charge.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @delivery_charge, url: admin_delivery_settings_path, local: true do |f| %>

            <div class="mb-3">
              <label for="delivery_charge_pincode" class="form-label fw-semibold">
                Pincode <span class="text-danger">*</span>
              </label>
              <%= f.text_field :pincode, class: "form-control", placeholder: "560001",
                    pattern: "[0-9]{6}", required: true, id: "delivery_charge_pincode" %>
              <div class="form-text">Enter 6-digit pincode</div>
            </div>

            <div class="mb-3">
              <label for="delivery_charge_area" class="form-label fw-semibold">Area</label>
              <%= f.text_field :area, class: "form-control",
                    placeholder: "e.g., MG Road, Bangalore Central", id: "delivery_charge_area" %>
            </div>

            <div class="mb-3">
              <label for="delivery_charge_charge_amount" class="form-label fw-semibold">
                Charge Amount (₹) <span class="text-danger">*</span>
              </label>
              <%= f.number_field :charge_amount, class: "form-control", min: 0, step: 0.01,
                    required: true, placeholder: "30.00", id: "delivery_charge_charge_amount" %>
            </div>

<div class="d-flex gap-2">
              <%= f.submit "Add Delivery Charge", class: "btn btn-primary px-4" %>
              <%= link_to "Cancel", admin_delivery_settings_path, class: "btn btn-outline-secondary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
