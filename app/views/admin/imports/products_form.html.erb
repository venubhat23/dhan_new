<% content_for :page_title, "Import Products" %>
<% content_for :page_subtitle, "Bulk Product Import" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="mb-1">
        <i class="fas fa-boxes me-2"></i>
        Import Products
      </h2>
      <p class="text-muted mb-0">Bulk upload product catalog from CSV or Excel files</p>
    </div>
    <div>
      <%= link_to admin_imports_path, class: "btn btn-outline-secondary" do %>
        <i class="fas fa-arrow-left me-1"></i>
        Back to Imports
      <% end %>
    </div>
  </div>

  <div class="row">
    <!-- Upload Form -->
    <div class="col-lg-8">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-teal text-white">
          <h5 class="mb-0">
            <i class="fas fa-cloud-upload-alt me-2"></i>
            Upload Product Data
          </h5>
        </div>
        <div class="card-body p-4">
          <%= form_with url: admin_import_products_path, multipart: true, local: true, class: "needs-validation", novalidate: true do |f| %>
            <div class="mb-4">
              <label for="file" class="form-label fw-bold">
                <i class="fas fa-file-csv me-2"></i>
                Select File
                <span class="text-danger">*</span>
              </label>
              <%= f.file_field :file,
                  class: "form-control form-control-lg",
                  accept: ".csv,.xlsx,.xls",
                  required: true,
                  id: "file" %>
              <div class="form-text">
                <i class="fas fa-info-circle me-1"></i>
                Supported formats: CSV, Excel (.xlsx, .xls). Maximum size: 10MB
              </div>
              <div class="invalid-feedback">
                Please select a valid file to upload.
              </div>
            </div>

            <!-- File Preview Section -->
            <div id="file-preview" class="mb-4" style="display: none;">
              <div class="alert alert-info">
                <div class="d-flex align-items-center">
                  <i class="fas fa-file-check me-2"></i>
                  <div>
                    <strong>File Selected:</strong> <span id="file-name"></span><br>
                    <small>Size: <span id="file-size"></span> | Type: <span id="file-type"></span></small>
                  </div>
                </div>
              </div>
            </div>

            <!-- Import Options -->
            <div class="card bg-light border-0 mb-4">
              <div class="card-body">
                <h6 class="card-title mb-3">
                  <i class="fas fa-cogs me-2"></i>
                  Import Options
                </h6>

                <div class="row g-3">
                  <div class="col-md-6">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" value="true" id="skip_header" name="skip_header" checked>
                      <label class="form-check-label" for="skip_header">
                        Skip header row
                      </label>
                    </div>
                  </div>

                  <div class="col-md-6">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" value="true" id="update_existing" name="update_existing">
                      <label class="form-check-label" for="update_existing">
                        Update existing products (match by SKU)
                      </label>
                    </div>
                  </div>

                  <div class="col-md-6">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" value="true" id="auto_generate_sku" name="auto_generate_sku" checked>
                      <label class="form-check-label" for="auto_generate_sku">
                        Auto-generate SKU if not provided
                      </label>
                    </div>
                  </div>

                  <div class="col-md-6">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" value="true" id="calculate_gst" name="calculate_gst" checked>
                      <label class="form-check-label" for="calculate_gst">
                        Auto-calculate GST amounts
                      </label>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
              <button type="submit" class="btn btn-teal btn-lg" id="submit-btn">
                <i class="fas fa-upload me-2"></i>
                Import Products
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <!-- Download Template Card -->
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0">
            <i class="fas fa-download me-2"></i>
            Download Template
          </h5>
        </div>
        <div class="card-body">
          <p class="card-text mb-3">
            Download the standardized template with all available product fields including pricing, GST, inventory, and subscription settings.
          </p>

          <div class="d-grid gap-2">
            <%= link_to download_template_admin_imports_path(template_type: 'products', format: 'csv'),
                class: "btn btn-success",
                target: "_blank" do %>
              <i class="fas fa-file-csv me-2"></i>
              Download CSV Template
            <% end %>

            <%= link_to download_template_admin_imports_path(template_type: 'products', format: 'xlsx'),
                class: "btn btn-outline-success",
                target: "_blank" do %>
              <i class="fas fa-file-excel me-2"></i>
              Download Excel Template
            <% end %>
          </div>
        </div>
      </div>

      <!-- Import Guidelines -->
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-info text-white">
          <h5 class="mb-0">
            <i class="fas fa-info-circle me-2"></i>
            Import Guidelines
          </h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <h6 class="text-primary mb-2">Simple Products:</h6>
            <ul class="list-unstyled small">
              <li><i class="fas fa-check text-success me-1"></i> <strong>name</strong> — product name</li>
              <li><i class="fas fa-check text-success me-1"></i> <strong>category_name</strong> — category (created if missing)</li>
              <li><i class="fas fa-check text-success me-1"></i> <strong>price</strong> — selling price</li>
              <li><i class="fas fa-circle text-muted me-1" style="font-size: 0.4rem;"></i> stock, buying_price, weight, unit_type</li>
              <li><i class="fas fa-circle text-muted me-1" style="font-size: 0.4rem;"></i> gst_enabled, gst_percentage, hsn_code</li>
              <li><i class="fas fa-circle text-muted me-1" style="font-size: 0.4rem;"></i> discount_type, discount_value, tags</li>
            </ul>
          </div>

          <div class="mb-3">
            <h6 class="text-primary mb-2">Variant Products (has_multiple_quantities = true):</h6>
            <p class="small text-muted mb-1">One row per variant. Repeat the product name/SKU across rows.</p>
            <ul class="list-unstyled small">
              <li><i class="fas fa-check text-success me-1"></i> <strong>variant_weight</strong> — e.g. 0.5, 1, 2</li>
              <li><i class="fas fa-check text-success me-1"></i> <strong>variant_unit</strong> — Liter, Kg, etc.</li>
              <li><i class="fas fa-check text-success me-1"></i> <strong>variant_selling_price</strong></li>
              <li><i class="fas fa-circle text-muted me-1" style="font-size: 0.4rem;"></i> variant_buying_price, variant_stock</li>
              <li><i class="fas fa-circle text-muted me-1" style="font-size: 0.4rem;"></i> variant_is_default (true for one row)</li>
              <li><i class="fas fa-circle text-muted me-1" style="font-size: 0.4rem;"></i> variant_discount_enabled, variant_discount_type, variant_discount_value</li>
              <li><i class="fas fa-circle text-muted me-1" style="font-size: 0.4rem;"></i> variant_gst_percentage, variant_display_order</li>
            </ul>
          </div>

          <div class="alert alert-warning small mb-0">
            <i class="fas fa-exclamation-triangle me-1"></i>
            <strong>Note:</strong> Rows with the same name or SKU are grouped as variants of the same product. Download the template for a working example.
          </div>
        </div>
      </div>

      <!-- CSV Format Examples -->
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">
            <i class="fas fa-table me-2"></i>
            CSV Format Examples
          </h5>
          <small class="opacity-75">Copy → paste into Excel / Google Sheets</small>
        </div>
        <div class="card-body p-3">

          <!-- Tab navigation -->
          <ul class="nav nav-tabs mb-3" id="csvExampleTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" id="simple-tab" data-bs-toggle="tab" data-bs-target="#simple-example" type="button" role="tab">
                <i class="fas fa-box me-1"></i> Simple Product
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="variant-tab" data-bs-toggle="tab" data-bs-target="#variant-example" type="button" role="tab">
                <i class="fas fa-layer-group me-1"></i> Variant Product
              </button>
            </li>
          </ul>

          <div class="tab-content" id="csvExampleTabsContent">

            <!-- Simple Product Example -->
            <div class="tab-pane fade show active" id="simple-example" role="tabpanel">
              <div class="table-responsive" style="font-size: 0.72rem;">
                <table class="table table-bordered table-sm csv-example-table mb-1">
                  <thead class="table-dark">
                    <tr>
                      <th>name</th>
                      <th>category_name</th>
                      <th>price</th>
                      <th>buying_price</th>
                      <th>stock</th>
                      <th>unit_type</th>
                      <th>discount_type</th>
                      <th>discount_value</th>
                      <th>gst_enabled</th>
                      <th>gst_percentage</th>
                      <th>hsn_code</th>
                      <th>status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="table-success">
                      <td>Amul Butter 100g</td>
                      <td>Dairy</td>
                      <td>55</td>
                      <td>45</td>
                      <td>100</td>
                      <td>Piece</td>
                      <td>percentage</td>
                      <td>10</td>
                      <td>true</td>
                      <td>5</td>
                      <td>0402</td>
                      <td>active</td>
                    </tr>
                    <tr class="table-success">
                      <td>Toor Dal</td>
                      <td>Pulses</td>
                      <td>120</td>
                      <td>95</td>
                      <td>50</td>
                      <td>Kg</td>
                      <td></td>
                      <td></td>
                      <td>false</td>
                      <td></td>
                      <td></td>
                      <td>active</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <small class="text-muted"><i class="fas fa-lightbulb me-1 text-warning"></i> <strong>discount_type</strong>: <code>percentage</code> or <code>fixed</code> &nbsp;|&nbsp; Leave blank for no discount</small>
            </div>

            <!-- Variant Product Example -->
            <div class="tab-pane fade" id="variant-example" role="tabpanel">
              <div class="alert alert-info py-2 px-3 mb-2 small">
                <i class="fas fa-info-circle me-1"></i>
                Repeat the <strong>same product name</strong> for each variant row. Set <code>has_multiple_quantities = true</code> on the first row.
              </div>
              <div class="table-responsive" style="font-size: 0.72rem;">
                <table class="table table-bordered table-sm csv-example-table mb-1">
                  <thead class="table-dark">
                    <tr>
                      <th>name</th>
                      <th>category_name</th>
                      <th>has_multiple_quantities</th>
                      <th>discount_type</th>
                      <th>discount_value</th>
                      <th class="table-warning">variant_weight</th>
                      <th class="table-warning">variant_unit</th>
                      <th class="table-warning">variant_buying_price</th>
                      <th class="table-warning">variant_selling_price</th>
                      <th class="table-warning">variant_stock</th>
                      <th class="table-warning">variant_is_default</th>
                      <th class="table-warning">variant_discount_enabled</th>
                      <th class="table-warning">variant_discount_type</th>
                      <th class="table-warning">variant_discount_value</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="table-success">
                      <td>Fresh Cow Milk</td>
                      <td>Dairy</td>
                      <td>true</td>
                      <td>percentage</td>
                      <td>10</td>
                      <td class="fw-semibold">0.5</td>
                      <td>Liter</td>
                      <td>32</td>
                      <td>22</td>
                      <td>200</td>
                      <td><span class="badge bg-success">true</span></td>
                      <td>false</td>
                      <td></td>
                      <td></td>
                    </tr>
                    <tr class="table-light">
                      <td>Fresh Cow Milk</td>
                      <td></td>
                      <td></td>
                      <td></td>
                      <td></td>
                      <td class="fw-semibold">1</td>
                      <td>Liter</td>
                      <td>60</td>
                      <td>42</td>
                      <td>150</td>
                      <td>false</td>
                      <td>false</td>
                      <td></td>
                      <td></td>
                    </tr>
                    <tr class="table-light">
                      <td>Fresh Cow Milk</td>
                      <td></td>
                      <td></td>
                      <td></td>
                      <td></td>
                      <td class="fw-semibold">2</td>
                      <td>Liter</td>
                      <td>112</td>
                      <td>80</td>
                      <td>80</td>
                      <td>false</td>
                      <td><span class="badge bg-warning text-dark">true</span></td>
                      <td>percentage</td>
                      <td>5</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <div class="row g-2 mt-1">
                <div class="col-12">
                  <small class="text-muted">
                    <i class="fas fa-info-circle me-1 text-primary"></i>
                    <strong>variant_is_default = true</strong> on the <em>first/main</em> variant (shown by default on product page) &nbsp;|&nbsp;
                    <strong>variant_discount_enabled = true</strong> activates per-variant discount &nbsp;|&nbsp;
                    <strong>discount_type / discount_value</strong> on the product row applies a product-level discount
                  </small>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Data Validation -->
      <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
          <h5 class="mb-0">
            <i class="fas fa-shield-alt me-2"></i>
            Data Validation
          </h5>
        </div>
        <div class="card-body">
          <ul class="list-unstyled small mb-0">
            <li class="mb-2">
              <i class="fas fa-check-circle text-success me-2"></i>
              Price / variant_selling_price validation
            </li>
            <li class="mb-2">
              <i class="fas fa-check-circle text-success me-2"></i>
              Category auto-created if missing
            </li>
            <li class="mb-2">
              <i class="fas fa-check-circle text-success me-2"></i>
              GST percentage validation
            </li>
            <li class="mb-2">
              <i class="fas fa-check-circle text-success me-2"></i>
              SKU uniqueness &amp; auto-generation
            </li>
            <li class="mb-2">
              <i class="fas fa-check-circle text-success me-2"></i>
              Variant grouping by name/SKU
            </li>
            <li class="mb-0">
              <i class="fas fa-check-circle text-success me-2"></i>
              Status, unit, and product type validation
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Custom file input styling */
.form-control[type="file"] {
  border: 2px dashed #dee2e6;
  background-color: #f8f9fa;
  padding: 1rem;
  transition: all 0.3s ease;
}

.form-control[type="file"]:hover {
  border-color: #17a2b8;
  background-color: #e3f2fd;
}

.form-control[type="file"]:focus {
  border-color: #17a2b8;
  background-color: #fff;
  box-shadow: 0 0 0 0.25rem rgba(23, 162, 184, 0.25);
}

.bg-teal {
  background-color: #17a2b8 !important;
}

.btn-teal {
  background-color: #17a2b8;
  border-color: #17a2b8;
  color: white;
}

.btn-teal:hover {
  background-color: #138496;
  border-color: #138496;
  color: white;
}

/* CSV example table */
.csv-example-table th, .csv-example-table td {
  white-space: nowrap;
  padding: 0.3rem 0.5rem;
}
.csv-example-table thead th {
  font-size: 0.68rem;
  letter-spacing: 0.02em;
}

/* Card animations */
.card {
  transition: all 0.3s ease;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1) !important;
}

/* Loading state for submit button */
.btn.loading {
  pointer-events: none;
  opacity: 0.7;
}

.btn.loading::after {
  content: "";
  display: inline-block;
  width: 1rem;
  height: 1rem;
  margin-left: 0.5rem;
  border: 2px solid transparent;
  border-top-color: currentColor;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const fileInput = document.getElementById('file');
  const filePreview = document.getElementById('file-preview');
  const fileName = document.getElementById('file-name');
  const fileSize = document.getElementById('file-size');
  const fileType = document.getElementById('file-type');
  const form = document.querySelector('form');
  const submitBtn = document.getElementById('submit-btn');

  // Handle file selection
  fileInput.addEventListener('change', function(e) {
    const file = e.target.files[0];

    if (file) {
      filePreview.style.display = 'block';
      fileName.textContent = file.name;
      fileSize.textContent = formatFileSize(file.size);
      fileType.textContent = file.type || 'Unknown';

      fileInput.classList.add('is-valid');
      fileInput.classList.remove('is-invalid');
    } else {
      filePreview.style.display = 'none';
      fileInput.classList.remove('is-valid');
    }
  });

  // Form submission handling
  form.addEventListener('submit', function(e) {
    submitBtn.classList.add('loading');
    submitBtn.disabled = true;
  });

  // File size formatter
  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  // Form validation
  form.addEventListener('submit', function(e) {
    if (!form.checkValidity()) {
      e.preventDefault();
      e.stopPropagation();
    }
    form.classList.add('was-validated');
  });

  // Drag and drop functionality
  ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
    fileInput.addEventListener(eventName, preventDefaults, false);
  });

  function preventDefaults(e) {
    e.preventDefault();
    e.stopPropagation();
  }

  ['dragenter', 'dragover'].forEach(eventName => {
    fileInput.addEventListener(eventName, highlight, false);
  });

  ['dragleave', 'drop'].forEach(eventName => {
    fileInput.addEventListener(eventName, unhighlight, false);
  });

  function highlight(e) {
    fileInput.style.borderColor = '#17a2b8';
    fileInput.style.backgroundColor = '#e3f2fd';
  }

  function unhighlight(e) {
    fileInput.style.borderColor = '#dee2e6';
    fileInput.style.backgroundColor = '#f8f9fa';
  }

  fileInput.addEventListener('drop', handleDrop, false);

  function handleDrop(e) {
    const dt = e.dataTransfer;
    const files = dt.files;

    if (files.length > 0) {
      fileInput.files = files;
      fileInput.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }
});
</script>