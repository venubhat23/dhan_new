<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @affiliate.display_name %></h2>
    <p class="text-muted mb-0">
      <span class="badge bg-purple me-2">
        Affiliate Partner
      </span>
      Affiliate ID: #<%= @affiliate.id %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <%= button_to toggle_status_admin_affiliate_path(@affiliate), method: :patch, class: "btn btn-#{@affiliate.status? ? 'warning' : 'success'}" do %>
      <i class="bi bi-#{@affiliate.status? ? 'pause-circle' : 'play-circle'} me-1"></i>
      <%= @affiliate.status? ? 'Deactivate' : 'Activate' %>
    <% end %>
    <%= button_to reset_password_admin_affiliate_path(@affiliate), method: :patch, class: "btn btn-info",
        data: { confirm: "This will generate a new password. Continue?" } do %>
      <i class="bi bi-key me-1"></i>
      Reset Password
    <% end %>
    <%= link_to edit_admin_affiliate_path(@affiliate), class: "btn btn-warning" do %>
      <i class="bi bi-pencil me-1"></i>
      Edit Affiliate
    <% end %>
    <%= link_to admin_affiliates_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Affiliates
    <% end %>
  </div>
</div>

<div class="row">
  <!-- Main Affiliate Information -->
  <div class="col-lg-8">
    <!-- Basic Information -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
          <i class="bi bi-person me-2 text-primary"></i>
          Basic Information
        </h5>
        <span class="badge bg-<%= @affiliate.status_badge_class %>">
          <%= @affiliate.status_text %>
        </span>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <strong class="text-muted d-block">First Name</strong>
            <%= @affiliate.first_name || '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Last Name</strong>
            <%= @affiliate.last_name || '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Middle Name</strong>
            <%= @affiliate.middle_name || '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Username</strong>
            <code class="bg-light px-2 py-1 rounded"><%= @affiliate.username || '-' %></code>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Email</strong>
            <% if @affiliate.email.present? %>
              <a href="mailto:<%= @affiliate.email %>">
                <i class="bi bi-envelope me-1"></i><%= @affiliate.email %>
              </a>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Mobile</strong>
            <% if @affiliate.mobile.present? %>
              <a href="tel:<%= @affiliate.mobile %>">
                <i class="bi bi-telephone me-1"></i><%= @affiliate.mobile %>
              </a>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Joining Date</strong>
            <%= @affiliate.joining_date&.strftime("%B %d, %Y") || @affiliate.created_at.strftime("%B %d, %Y") %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Commission Rate</strong>
            <span class="badge bg-success fs-6"><%= @affiliate.formatted_commission %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Login Credentials -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
          <i class="bi bi-key me-2 text-primary"></i>
          Login Credentials
        </h5>
        <% if @affiliate.user %>
          <span class="badge bg-<%= @affiliate.user.status? ? 'success' : 'danger' %>">
            Account <%= @affiliate.user.status? ? 'Active' : 'Inactive' %>
          </span>
        <% end %>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <strong class="text-muted d-block">Username</strong>
            <div class="d-flex align-items-center gap-2">
              <code class="bg-light px-2 py-1 rounded fs-6">
                <%= @affiliate.username.present? ? @affiliate.username : (@affiliate.user&.email || '-') %>
              </code>
              <% login_username = @affiliate.username.presence || @affiliate.user&.email %>
              <% if login_username.present? %>
                <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('<%= login_username %>')" title="Copy username">
                  <i class="bi bi-copy"></i>
                </button>
              <% end %>
            </div>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Password</strong>
            <div class="d-flex align-items-center gap-2">
              <% if @affiliate.auto_generated_password.present? %>
                <code class="bg-light px-2 py-1 rounded fs-6 font-monospace" id="passwordDisplay">
                  <%= @affiliate.auto_generated_password %>
                </code>
                <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('<%= @affiliate.auto_generated_password %>')" title="Copy password">
                  <i class="bi bi-copy"></i>
                </button>
              <% else %>
                <span class="text-muted fst-italic">Not stored — use Reset Password to generate a new one</span>
              <% end %>
            </div>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Login Email</strong>
            <div class="d-flex align-items-center gap-2">
              <span><%= @affiliate.email %></span>
              <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('<%= @affiliate.email %>')" title="Copy email">
                <i class="bi bi-copy"></i>
              </button>
            </div>
          </div>
          <% if @affiliate.user %>
            <div class="col-md-6">
              <strong class="text-muted d-block">Account Status</strong>
              <span class="badge bg-<%= @affiliate.user.status? ? 'success' : 'danger' %>">
                <i class="bi bi-<%= @affiliate.user.status? ? 'check' : 'x' %>-circle me-1"></i>
                <%= @affiliate.user.status? ? 'Active' : 'Inactive' %>
              </span>
            </div>
          <% end %>
          <div class="col-12">
            <div class="alert alert-info mb-0">
              <i class="bi bi-info-circle me-2"></i>
              <strong>Affiliate Portal URL:</strong>
              <a href="<%= request.base_url %>/affiliate/login" target="_blank" class="alert-link">
                <%= request.base_url %>/affiliate/login
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Address & Location -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-geo-alt me-2 text-success"></i>
          Address & Location
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <% if @affiliate.address.present? %>
            <div class="col-12">
              <strong class="text-muted d-block">Full Address</strong>
              <%= @affiliate.address %>
            </div>
          <% end %>
          <div class="col-md-4">
            <strong class="text-muted d-block">City</strong>
            <%= @affiliate.city || '-' %>
          </div>
          <div class="col-md-4">
            <strong class="text-muted d-block">State</strong>
            <%= @affiliate.state || '-' %>
          </div>
          <div class="col-md-4">
            <strong class="text-muted d-block">PIN Code</strong>
            <%= @affiliate.pincode || '-' %>
          </div>
        </div>
      </div>
    </div>

    <!-- Business Information -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-briefcase me-2 text-warning"></i>
          Business Information
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <strong class="text-muted d-block">Company Name</strong>
            <%= @affiliate.company_name || '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Commission Percentage</strong>
            <span class="h5 text-success"><%= @affiliate.formatted_commission %></span>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">PAN Number</strong>
            <% if @affiliate.pan_no.present? %>
              <code class="bg-light px-2 py-1 rounded"><%= @affiliate.pan_no %></code>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">GST Number</strong>
            <% if @affiliate.gst_no.present? %>
              <code class="bg-light px-2 py-1 rounded"><%= @affiliate.gst_no %></code>
            <% else %>
              -
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Banking Information -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-bank me-2 text-info"></i>
          Banking Information
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <strong class="text-muted d-block">Bank Name</strong>
            <%= @affiliate.bank_name || '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Account Holder Name</strong>
            <%= @affiliate.account_holder_name || '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Account Number</strong>
            <% if @affiliate.account_no.present? %>
              <code class="bg-light px-2 py-1 rounded">***<%= @affiliate.account_no.last(4) %></code>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">IFSC Code</strong>
            <% if @affiliate.ifsc_code.present? %>
              <code class="bg-light px-2 py-1 rounded"><%= @affiliate.ifsc_code %></code>
            <% else %>
              -
            <% end %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">Account Type</strong>
            <%= @affiliate.account_type&.titleize || '-' %>
          </div>
          <div class="col-md-6">
            <strong class="text-muted d-block">UPI ID</strong>
            <% if @affiliate.upi_id.present? %>
              <code class="bg-light px-2 py-1 rounded"><%= @affiliate.upi_id %></code>
            <% else %>
              -
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Additional Notes -->
    <% if @affiliate.notes.present? %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-journal-text me-2 text-info"></i>
          Additional Notes
        </h5>
      </div>
      <div class="card-body">
        <div class="p-3 bg-light rounded">
          <%= simple_format(@affiliate.notes) %>
        </div>
      </div>
    </div>
    <% end %>

    <!-- Referral Activity -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h5 class="mb-0">
          <i class="bi bi-people me-2 text-primary"></i>
          Referral Activity
        </h5>
      </div>
      <div class="card-body">
        <div class="row g-3 text-center">
          <div class="col-md-3">
            <div class="border rounded p-3">
              <h4 class="text-primary mb-1"><%= @affiliate.total_referrals %></h4>
              <small class="text-muted">Total Referrals</small>
            </div>
          </div>
          <div class="col-md-3">
            <div class="border rounded p-3">
              <h4 class="text-warning mb-1"><%= @affiliate.pending_referrals %></h4>
              <small class="text-muted">Pending</small>
            </div>
          </div>
          <div class="col-md-3">
            <div class="border rounded p-3">
              <h4 class="text-info mb-1"><%= @affiliate.registered_referrals %></h4>
              <small class="text-muted">Registered</small>
            </div>
          </div>
          <div class="col-md-3">
            <div class="border rounded p-3">
              <h4 class="text-success mb-1"><%= @affiliate.converted_referrals %></h4>
              <small class="text-muted">Converted</small>
            </div>
          </div>
        </div>

        <% if @affiliate.referrals.any? %>
          <hr>
          <h6 class="mb-3">Recent Referrals</h6>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Customer</th>
                  <th>Email/Mobile</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @affiliate.referrals.order(created_at: :desc).limit(5).each do |referral| %>
                  <tr>
                    <td><%= referral.referred_name || referral.customer&.display_name || '-' %></td>
                    <td>
                      <small>
                        <%= referral.referred_email || referral.customer&.email || '-' %><br>
                        <%= referral.referred_mobile || referral.customer&.mobile || '-' %>
                      </small>
                    </td>
                    <td><%= referral.created_at.strftime("%b %d, %Y") %></td>
                    <td>
                      <span class="badge bg-<%= referral.status == 'converted' ? 'success' : referral.status == 'registered' ? 'info' : 'warning' %>">
                        <%= referral.status&.titleize || 'Pending' %>
                      </span>
                    </td>
                    <td>
                      <% if referral.customer %>
                        <%= link_to "View Customer", admin_customer_path(referral.customer), class: "btn btn-sm btn-outline-primary" %>
                      <% else %>
                        <small class="text-muted">Not registered</small>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="text-center mt-3">
            <%= link_to "View All Referrals", admin_referrals_path(affiliate_id: @affiliate.id), class: "btn btn-outline-primary" %>
          </div>
        <% else %>
          <div class="text-center text-muted py-4">
            <i class="bi bi-people-fill fs-1 d-block mb-3"></i>
            <h6>No Referrals Yet</h6>
            <p class="mb-0">This affiliate hasn't made any referrals yet.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="col-lg-4">
    <!-- Quick Stats -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">
          <i class="bi bi-bar-chart me-1"></i>
          Quick Stats
        </h6>
      </div>
      <div class="card-body">
        <div class="row g-2 text-center">
          <div class="col-12 mb-2">
            <small class="text-muted d-block">Affiliate Since</small>
            <strong><%= (@affiliate.joining_date || @affiliate.created_at).strftime("%B %Y") %></strong>
          </div>
          <hr>
          <div class="col-6">
            <small class="text-muted d-block">Total Referrals</small>
            <h5 class="text-primary mb-0"><%= @affiliate.total_referrals %></h5>
          </div>
          <div class="col-6">
            <small class="text-muted d-block">Conversion Rate</small>
            <h5 class="text-success mb-0"><%= @affiliate.conversion_rate %>%</h5>
          </div>
          <div class="col-12 mt-2">
            <small class="text-muted d-block">Commission Rate</small>
            <h4 class="text-warning mb-0"><%= @affiliate.formatted_commission %></h4>
          </div>
        </div>
      </div>
    </div>

    <!-- Affiliate Timeline -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">
          <i class="bi bi-clock-history me-1"></i>
          Affiliate Timeline
        </h6>
      </div>
      <div class="card-body">
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-marker bg-success"></div>
            <div class="timeline-content">
              <small class="text-muted">Affiliate Created</small>
              <div><%= @affiliate.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
            </div>
          </div>
          <% if @affiliate.joining_date && @affiliate.joining_date != @affiliate.created_at.to_date %>
            <div class="timeline-item">
              <div class="timeline-marker bg-primary"></div>
              <div class="timeline-content">
                <small class="text-muted">Officially Joined</small>
                <div><%= @affiliate.joining_date.strftime("%B %d, %Y") %></div>
              </div>
            </div>
          <% end %>
          <% if @affiliate.updated_at != @affiliate.created_at %>
            <div class="timeline-item">
              <div class="timeline-marker bg-info"></div>
              <div class="timeline-content">
                <small class="text-muted">Last Updated</small>
                <div><%= @affiliate.updated_at.strftime("%B %d, %Y at %I:%M %p") %></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Status Card -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0">
        <h6 class="mb-0">
          <i class="bi bi-shield-check me-1"></i>
          Account Status
        </h6>
      </div>
      <div class="card-body text-center">
        <div class="mb-3">
          <span class="badge bg-<%= @affiliate.status_badge_class %> fs-6 px-3 py-2">
            <i class="bi bi-<%= @affiliate.status? ? 'check' : 'x' %>-circle me-1"></i>
            <%= @affiliate.status_text %>
          </span>
        </div>
        <% if @affiliate.user %>
          <small class="text-muted d-block">
            User Account:
            <span class="badge bg-<%= @affiliate.user.status? ? 'success' : 'danger' %>">
              <%= @affiliate.user.status? ? 'Active' : 'Inactive' %>
            </span>
          </small>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
.bg-purple {
  background-color: #8b5cf6 !important;
}

.timeline {
  position: relative;
  padding-left: 20px;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 8px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: #dee2e6;
}

.timeline-item {
  position: relative;
  margin-bottom: 1rem;
}

.timeline-marker {
  position: absolute;
  left: -15px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid #fff;
}

.timeline-content {
  padding-left: 10px;
}
</style>

<script>
function copyToClipboard(text) {
  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(text).then(() => {
      showCopySuccess();
    }).catch(err => {
      console.error('Failed to copy: ', err);
      fallbackCopyTextToClipboard(text);
    });
  } else {
    fallbackCopyTextToClipboard(text);
  }
}

function fallbackCopyTextToClipboard(text) {
  const textArea = document.createElement("textarea");
  textArea.value = text;
  textArea.style.top = "0";
  textArea.style.left = "0";
  textArea.style.position = "fixed";
  document.body.appendChild(textArea);
  textArea.focus();
  textArea.select();

  try {
    const successful = document.execCommand('copy');
    if (successful) {
      showCopySuccess();
    } else {
      console.error('Fallback: Copying text command was unsuccessful');
    }
  } catch (err) {
    console.error('Fallback: Oops, unable to copy', err);
  }

  document.body.removeChild(textArea);
}

function showCopySuccess() {
  const message = document.createElement('div');
  message.className = 'alert alert-success position-fixed top-0 end-0 m-3';
  message.style.zIndex = '9999';
  message.innerHTML = '<i class="bi bi-check-circle me-2"></i>Copied to clipboard!';
  document.body.appendChild(message);

  setTimeout(() => {
    if (document.body.contains(message)) {
      document.body.removeChild(message);
    }
  }, 2000);
}
</script>