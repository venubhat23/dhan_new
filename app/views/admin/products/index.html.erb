<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteProductModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title text-danger">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Product
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-3">You are about to permanently delete <strong id="deleteProductName"></strong>.</p>

        <div id="deleteDepLoading" class="text-center py-3">
          <div class="spinner-border spinner-border-sm text-secondary me-2"></div>
          <span class="text-muted small">Checking associated records…</span>
        </div>

        <div id="deleteDepContent" class="d-none">
          <div id="deleteDepNone" class="d-none">
            <div class="alert alert-success border-0 py-2 mb-3">
              <i class="bi bi-check-circle me-2"></i>No associated records found. Safe to delete.
            </div>
          </div>
          <div id="deleteDepWarning" class="d-none">
            <div class="alert alert-warning border-0 py-2 mb-3">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <strong>The following associated records will also be permanently deleted:</strong>
            </div>
            <ul class="list-group list-group-flush mb-3" id="deleteDepList"></ul>
            <div id="deleteDepBookings" class="d-none mb-3">
              <p class="small fw-semibold text-muted mb-1">Linked Bookings (up to 5):</p>
              <ul class="list-unstyled small" id="deleteDepBookingList"></ul>
            </div>
            <div id="deleteDepInvoices" class="d-none mb-3">
              <p class="small fw-semibold text-muted mb-1">Linked Invoices (up to 5):</p>
              <ul class="list-unstyled small" id="deleteDepInvoiceList"></ul>
            </div>
          </div>
        </div>

        <p class="text-danger small mb-0"><i class="bi bi-exclamation-circle me-1"></i>This action cannot be undone.</p>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <%= form_with url: "#", method: :delete, id: "deleteProductForm", local: false, data: { turbo: false } do |f| %>
          <%= hidden_field_tag :_method, "delete" %>
          <button type="submit" class="btn btn-danger" id="deleteProductConfirmBtn" disabled>
            <i class="bi bi-trash me-1"></i>Yes, Delete Everything
          </button>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Product Management</h2>
    <p class="text-muted mb-0">Manage your product inventory and catalog</p>
  </div>
  <div>
    <%= link_to new_admin_product_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Product
    <% end %>
  </div>
</div>

<!-- Stats Cards -->
