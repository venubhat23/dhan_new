<!-- Hidden delete form — reused for all product deletes -->
<form id="deleteProductForm" method="post" style="display:none">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <%= hidden_field_tag :_method, "delete" %>
</form>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Product Management</h2>
    <p class="text-muted mb-0">Manage your product inventory and catalog</p>
  </div>
  <div>
    <%= link_to new_admin_product_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i>
      Add New Product
    <% end %>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total Products</h6>
            <h4 class="mb-0"><%= @products.respond_to?(:total_count) ? @products.total_count : @products.count %></h4>
          </div>
          <div class="text-primary">
            <i class="bi bi-box-seam fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Active Products</h6>
            <h4 class="mb-0"><%= @products.respond_to?(:select) ? @products.select { |p| p.status == 'active' }.count : 0 %></h4>
          </div>
          <div class="text-success">
            <i class="bi bi-check-circle fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">In Stock</h6>
            <h4 class="mb-0"><%= @products.respond_to?(:select) ? @products.select { |p| p.stock.to_i > 0 }.count : 0 %></h4>
          </div>
          <div class="text-info">
            <i class="bi bi-box fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Low Stock</h6>
            <h4 class="mb-0"><%= @products.respond_to?(:select) ? @products.select { |p| p.stock.to_i > 0 && p.stock.to_i <= (p.low_stock_threshold || 10) }.count : 0 %></h4>
          </div>
          <div class="text-warning">
            <i class="bi bi-exclamation-triangle fs-2"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function confirmDeleteProduct(productName, deleteUrl) {
  if (confirm('Delete "' + productName + '"?\n\nThis will permanently remove the product and all associated data. This cannot be undone.')) {
    var form = document.getElementById('deleteProductForm');
    form.action = deleteUrl;
    form.submit();
  }
}

document.addEventListener('DOMContentLoaded', function() {
  // Search functionality
  const searchInput = document.getElementById('searchInput');
  const tableRows = document.querySelectorAll('tbody tr');

  searchInput?.addEventListener('input', function() {
    const searchTerm = this.value.toLowerCase();

    tableRows.forEach(row => {
      const productName = row.cells[1]?.textContent.toLowerCase() || '';
      const category = row.cells[2]?.textContent.toLowerCase() || '';

      if (productName.includes(searchTerm) || category.includes(searchTerm)) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  });

  // Select All checkbox
  const selectAll = document.getElementById('selectAllProducts');
  const productCheckboxes = document.querySelectorAll('.product-checkbox');
  const bulkBar = document.getElementById('bulkActionBar');
  const selectedCount = document.getElementById('selectedCount');
  const bulkActionInput = document.getElementById('bulkActionInput');

  function updateBulkBar() {
    const checked = document.querySelectorAll('.product-checkbox:checked').length;
    if (checked > 0) {
      bulkBar.classList.remove('d-none');
      selectedCount.textContent = checked + ' product' + (checked === 1 ? '' : 's') + ' selected';
    } else {
      bulkBar.classList.add('d-none');
    }
    if (selectAll) {
      selectAll.indeterminate = checked > 0 && checked < productCheckboxes.length;
      selectAll.checked = checked === productCheckboxes.length && productCheckboxes.length > 0;
    }
  }

  selectAll?.addEventListener('change', function() {
    productCheckboxes.forEach(cb => cb.checked = this.checked);
    updateBulkBar();
  });

  productCheckboxes.forEach(cb => cb.addEventListener('change', updateBulkBar));

  // Bulk action buttons
  document.querySelectorAll('[data-bulk-action]').forEach(btn => {
    btn.addEventListener('click', function() {
      const action = this.dataset.bulkAction;
      const checked = document.querySelectorAll('.product-checkbox:checked');
      if (checked.length === 0) return;

      const confirmMessages = {
        delete: 'Delete ' + checked.length + ' selected product(s)? This cannot be undone.',
        deactivate: 'Deactivate ' + checked.length + ' selected product(s)?',
        activate: 'Activate ' + checked.length + ' selected product(s)?'
      };

      if (!confirm(confirmMessages[action] || 'Confirm action?')) return;

      bulkActionInput.value = action;
      document.getElementById('bulkActionForm').submit();
    });
  });
});
</script>

<!-- Filter Bar -->
<%= form_with url: admin_products_path, method: :get, local: true, class: "mb-3" do |f| %>
  <div class="card border-0 shadow-sm">
    <div class="card-body py-3">
      <div class="row g-2 align-items-end">
        <div class="col-md-4">
          <label class="form-label small text-muted mb-1">Search</label>
          <%= f.text_field :search, value: params[:search], class: "form-control", placeholder: "Search products..." %>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-muted mb-1">Category</label>
          <%= f.select :category_id,
                options_for_select([['All Categories', '']] + @categories.map { |c| [c.name, c.id] }, params[:category_id]),
                {},
                class: "form-select" %>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-muted mb-1">Status</label>
          <%= f.select :status,
                options_for_select([['All Statuses', ''], ['Active', 'active'], ['Inactive', 'inactive'], ['Draft', 'draft']], params[:status]),
                {},
                class: "form-select" %>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-muted mb-1">Stock</label>
          <%= f.select :stock_status,
                options_for_select([['All Stock', ''], ['In Stock', 'in_stock'], ['Out of Stock', 'out_of_stock']], params[:stock_status]),
                {},
                class: "form-select" %>
        </div>
        <div class="col-md-1 d-flex gap-1">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-search"></i>
          </button>
          <% if params[:search].present? || params[:category_id].present? || params[:status].present? || params[:stock_status].present? %>
            <%= link_to admin_products_path, class: "btn btn-outline-secondary" do %>
              <i class="bi bi-x-lg"></i>
            <% end %>
          <% end %>
        </div>
      </div>
      <% if params[:category_id].present? %>
        <% selected_cat = @categories.find { |c| c.id.to_s == params[:category_id].to_s } %>
        <% if selected_cat %>
          <div class="mt-2">
            <span class="badge bg-primary-subtle text-primary">
              <i class="bi bi-tag me-1"></i>Category: <%= selected_cat.name %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Products Table -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">
        Product Catalog
        <% if params[:category_id].present? %>
          <% selected_cat = @categories.find { |c| c.id.to_s == params[:category_id].to_s } %>
          <small class="text-muted fw-normal ms-1">— <%= selected_cat&.name %></small>
        <% end %>
      </h5>
      <small class="text-muted"><%= @products.respond_to?(:total_count) ? @products.total_count : @products.count %> product(s)</small>
    </div>
  </div>

  <!-- Bulk Action Bar (hidden until items selected) -->
  <div id="bulkActionBar" class="d-none px-3 py-2 bg-primary-subtle border-bottom d-flex align-items-center gap-3 flex-wrap">
    <span id="selectedCount" class="fw-medium text-primary small"></span>
    <button type="button" class="btn btn-sm btn-primary" id="bulkEditBtn">
      <i class="bi bi-pencil-square me-1"></i>Bulk Edit
    </button>
    <button type="button" class="btn btn-sm btn-success" data-bulk-action="activate">
      <i class="bi bi-check-circle me-1"></i>Activate
    </button>
    <button type="button" class="btn btn-sm btn-warning" data-bulk-action="deactivate">
      <i class="bi bi-dash-circle me-1"></i>Deactivate
    </button>
    <button type="button" class="btn btn-sm btn-danger" data-bulk-action="delete">
      <i class="bi bi-trash me-1"></i>Delete Selected
    </button>
  </div>

  <div class="card-body p-0">
    <% if @products.any? %>
      <%= form_with url: bulk_action_admin_products_path, method: :post, id: "bulkActionForm", local: true do |f| %>
        <%= hidden_field_tag :bulk_action, '', id: 'bulkActionInput' %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th class="border-0 ps-3" style="width: 40px;">
                  <input type="checkbox" id="selectAllProducts" class="form-check-input">
                </th>
                <th class="border-0 fw-semibold">Product</th>
                <th class="border-0 fw-semibold">Category</th>
                <th class="border-0 fw-semibold">Price & Profit</th>
                <th class="border-0 fw-semibold">Stock</th>
                <th class="border-0 fw-semibold">Status</th>
                <th class="border-0 fw-semibold">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @products.each do |product| %>
                <tr data-product-id="<%= product.id %>"
                    data-product='<%= { id: product.id, name: product.name, price: product.price.to_f, buying_price: product.buying_price.to_f, purchase_price: product.purchase_price.to_f, stock: product.stock.to_i, unit_type: product.unit_type, status: product.status, category_id: product.category_id }.to_json %>'>
                  <td class="align-middle ps-3">
                    <input type="checkbox" name="product_ids[]" value="<%= product.id %>" class="form-check-input product-checkbox">
                  </td>
                  <td class="align-middle">
                    <div class="d-flex align-items-center">
                      <div class="position-relative me-3">
                        <% if product.r2_image_url.present? %>
                          <img src="<%= product.r2_image_url %>"
                               alt="<%= product.name %>"
                               class="rounded-circle object-fit-cover"
                               style="width: 40px; height: 40px;">
                        <% elsif product.main_image_url.present? %>
                          <img src="<%= product.main_image_url(width: 60, height: 60) %>"
                               alt="<%= product.name %>"
                               class="rounded-circle object-fit-cover"
                               style="width: 40px; height: 40px;">
                        <% elsif product.image.attached? %>
                          <%= image_tag product.image,
                              alt: product.name,
                              class: "rounded-circle object-fit-cover",
                              style: "width: 40px; height: 40px;" %>
                        <% else %>
                          <div class="avatar-sm bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-box-seam text-primary"></i>
                          </div>
                        <% end %>
                      </div>
                      <div>
                        <h6 class="mb-0"><%= link_to product.name, admin_product_path(product), class: "text-dark text-decoration-none fw-semibold link-hover" %></h6>
                        <small class="text-muted">SKU: <%= product.sku || 'N/A' %></small>
                        <% if product.image_url.present? %>
                          <small class="text-success d-block">
                            <i class="bi bi-cloud-check me-1"></i>Cloudinary
                          </small>
                        <% elsif product.image.attached? %>
                          <small class="text-info d-block">
                            <i class="bi bi-server me-1"></i>Local
                          </small>
                        <% end %>
                      </div>
                    </div>
                  </td>
                  <td class="align-middle">
                    <span class="badge bg-secondary-subtle text-secondary"><%= product.category&.name || 'No Category' %></span>
                  </td>
                  <td class="align-middle">
                    <div>
                      <!-- Selling Price -->
                      <div class="d-flex align-items-center gap-2">
                        <span class="fw-medium">
                          <%= product.respond_to?(:formatted_selling_price) ? product.formatted_selling_price : number_to_currency(product.final_price_after_discount) %>
                        </span>
                        <% if product.discounted? %>
                          <small class="badge bg-success-subtle text-success">
                            <%= product.discount_percentage.round(1) %>% OFF
                          </small>
                        <% end %>
                      </div>

                      <!-- Discount Info -->
                      <% if product.discounted? %>
                        <small class="text-muted text-decoration-line-through">
                          MRP: <%= number_to_currency(product.original_price || product.price) %>
                        </small>
                        <br>
                      <% end %>

                      <!-- Profit Info -->
                      <% if product.buying_price.present? %>
                        <div class="small mt-1">
                          <span class="text-muted">Cost: ₹<%= product.buying_price.round(2) %></span>
                          <span class="mx-1">•</span>
                          <span class="<%= product.profit_status_class %> fw-medium">
                            Profit: ₹<%= product.profit_amount.round(2) %>
                          </span>
                          <% if product.profit_percentage != 0 %>
                            <span class="mx-1">•</span>
                            <span class="<%= product.profit_status_class %> fw-medium">
                              <%= product.profit_margin_percentage.round(1) %>%
                            </span>
                          <% end %>
                        </div>
                        <div class="small">
                          <span class="badge bg-<%= product.profitable? ? 'success' : (product.profit_amount == 0 ? 'warning' : 'danger') %>-subtle text-<%= product.profitable? ? 'success' : (product.profit_amount == 0 ? 'warning' : 'danger') %>">
                            <%= product.profit_status %>
                          </span>
                        </div>
                      <% else %>
                        <small class="text-muted">No cost price set</small>
                      <% end %>
                    </div>
                  </td>
                  <td class="align-middle">
                    <% threshold = product.low_stock_threshold || 10 %>
                    <% if product.stock.to_i > threshold %>
                      <span class="text-success fw-medium"><%= product.stock %> <%= product.unit_type %></span>
                      <div class="small text-muted">In Stock</div>
                    <% elsif product.stock.to_i > 0 %>
                      <span class="text-warning fw-medium"><%= product.stock %> <%= product.unit_type %></span>
                      <div class="small text-warning">
                        <i class="bi bi-exclamation-triangle me-1"></i>Low Stock
                      </div>
                    <% else %>
                      <span class="text-danger fw-medium">0 <%= product.unit_type %></span>
                      <div class="small text-muted">Out of Stock</div>
                    <% end %>
                    <div class="small text-muted">Threshold: <%= threshold %></div>
                  </td>
                  <td class="align-middle">
                    <% case product.status %>
                    <% when 'active' %>
                      <span class="badge bg-success-subtle text-success">
                        <i class="bi bi-check-circle me-1"></i>
                        Active
                      </span>
                    <% when 'inactive' %>
                      <span class="badge bg-danger-subtle text-danger">
                        <i class="bi bi-x-circle me-1"></i>
                        Inactive
                      </span>
                    <% when 'draft' %>
                      <span class="badge bg-warning-subtle text-warning">
                        <i class="bi bi-clock me-1"></i>
                        Draft
                      </span>
                    <% else %>
                      <span class="badge bg-secondary-subtle text-secondary"><%= product.status&.humanize || 'Unknown' %></span>
                    <% end %>
                  </td>
                  <td class="align-middle">
                    <div class="dropdown">
                      <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots"></i>
                      </button>
                      <ul class="dropdown-menu">
                        <li>
                          <%= link_to admin_product_path(product), class: "dropdown-item" do %>
                            <i class="bi bi-eye me-2"></i>
                            View Details
                          <% end %>
                        </li>
                        <li>
                          <%= link_to edit_admin_product_path(product), class: "dropdown-item" do %>
                            <i class="bi bi-pencil me-2"></i>
                            Edit Product
                          <% end %>
                        </li>
                        <li>
                          <%= link_to manage_images_admin_product_path(product), class: "dropdown-item" do %>
                            <i class="bi bi-image me-2"></i>
                            Change Image
                          <% end %>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                          <button type="button"
                                  class="dropdown-item text-danger"
                                  onclick="confirmDeleteProduct('<%= j(product.name) %>', '<%= admin_product_path(product) %>')">
                            <i class="bi bi-trash me-2"></i>
                            Delete Product
                          </button>
                        </li>
                      </ul>
                    </div>
                  </td>
                </tr>
              <% end %>

            </tbody>
          </table>
        </div>
      <% end %>

      <!-- Pagination -->
      <% if respond_to?(:paginate) && @products.respond_to?(:total_pages) %>
        <div class="card-footer bg-transparent border-0">
          <%= paginate @products %>
        </div>
      <% end %>

      <!-- Bulk Edit Form (hidden, submitted by modal) -->
      <form id="bulkEditForm" method="post" action="<%= bulk_update_admin_products_path %>">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <div id="bulkEditFields"></div>
      </form>
    <% else %>
      <div class="text-center py-5">
        <div class="mb-3">
          <i class="bi bi-box-seam fs-1 text-muted"></i>
        </div>
        <% if params[:search].present? %>
          <h5 class="text-muted mb-3">No products found for "<%= params[:search] %>"</h5>
          <p class="text-muted mb-4">We couldn't find any matching products. You can create a new one instead.</p>
          <%= link_to new_admin_product_path(name: params[:search]), class: "btn btn-primary" do %>
            <i class="bi bi-plus-lg me-1"></i>Create "<%= params[:search] %>"
          <% end %>
        <% else %>
          <h5 class="text-muted mb-3">No Products Found</h5>
          <p class="text-muted mb-4">Start by adding your first product to build your catalog and manage inventory.</p>
          <%= link_to "Add Product", new_admin_product_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<% content_for :modals do %>
<!-- Bulk Edit Modal -->
<div class="modal fade" id="bulkEditModal" tabindex="-1" aria-labelledby="bulkEditModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="bulkEditModalLabel">
          <i class="bi bi-pencil-square me-2"></i>Bulk Edit Products
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div class="table-responsive">
          <table class="table table-bordered align-middle mb-0" id="bulkEditTable">
            <thead class="sticky-top" style="background:#f1f3f5;">
              <tr>
                <th style="min-width:160px;">Product Name</th>
                <th style="min-width:100px;">Sell Price (₹)</th>
                <th style="min-width:100px;">Cost Price (₹)</th>
                <th style="min-width:110px;">Purchase Price (₹)</th>
                <th style="min-width:80px;">Stock</th>
                <th style="min-width:110px;">Unit</th>
                <th style="min-width:100px;">Status</th>
                <th style="min-width:140px;">Category</th>
              </tr>
            </thead>
            <tbody id="bulkEditBody">
            </tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="bulkEditSaveBtn">
          <i class="bi bi-check-lg me-1"></i>Save All Changes
        </button>
      </div>
    </div>
  </div>
</div>
<% end %>

<script>
(function() {
  const UNIT_TYPES   = <%= Product::UNIT_TYPES.map(&:last).to_json.html_safe %>;
  const CATEGORIES   = <%= @categories.map { |c| [c.id, c.name] }.to_json.html_safe %>;
  const STATUSES     = [['active','Active'],['inactive','Inactive'],['draft','Draft']];

  function buildSelect(name, options, selected, extraClass) {
    let html = `<select name="${name}" class="form-select form-select-sm ${extraClass||''}">`;
    options.forEach(([val, label]) => {
      html += `<option value="${val}"${val == selected ? ' selected' : ''}>${label}</option>`;
    });
    html += '</select>';
    return html;
  }

  function openBulkEditModal() {
    const checked = document.querySelectorAll('.product-checkbox:checked');
    if (checked.length === 0) return;

    const tbody = document.getElementById('bulkEditBody');
    tbody.innerHTML = '';

    checked.forEach(cb => {
      const row = cb.closest('tr');
      const p   = JSON.parse(row.dataset.product);
      const id  = p.id;

      const unitOptions  = UNIT_TYPES.map(u => [u, u]);
      const catOptions   = [['' , '— No Category —'], ...CATEGORIES];

      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>
          <input type="text" name="products[${id}][name]"
                 class="form-control form-control-sm"
                 value="${escHtml(p.name)}" required>
        </td>
        <td>
          <input type="number" name="products[${id}][price]"
                 class="form-control form-control-sm"
                 value="${p.price}" min="0" step="0.01">
        </td>
        <td>
          <input type="number" name="products[${id}][buying_price]"
                 class="form-control form-control-sm"
                 value="${p.buying_price}" min="0" step="0.01">
        </td>
        <td>
          <input type="number" name="products[${id}][purchase_price]"
                 class="form-control form-control-sm"
                 value="${p.purchase_price}" min="0" step="0.01">
        </td>
        <td>
          <input type="number" name="products[${id}][stock]"
                 class="form-control form-control-sm"
                 value="${p.stock}" min="0" step="1">
        </td>
        <td>${buildSelect(`products[${id}][unit_type]`, unitOptions, p.unit_type)}</td>
        <td>${buildSelect(`products[${id}][status]`, STATUSES, p.status)}</td>
        <td>${buildSelect(`products[${id}][category_id]`, catOptions, p.category_id)}</td>
      `;
      tbody.appendChild(tr);
    });

    new bootstrap.Modal(document.getElementById('bulkEditModal')).show();
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  document.getElementById('bulkEditBtn').addEventListener('click', openBulkEditModal);

  document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('bulkEditSaveBtn').addEventListener('click', function() {
      const tbody = document.getElementById('bulkEditBody');
      if (tbody.children.length === 0) return;

      const btn = this;
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Saving…';

      const container = document.getElementById('bulkEditFields');
      container.innerHTML = '';
      tbody.querySelectorAll('input, select').forEach(el => {
        const clone = el.cloneNode(true);
        clone.style.display = 'none';
        container.appendChild(clone);
      });

      document.getElementById('bulkEditForm').submit();
    });
  });
})();
</script>
