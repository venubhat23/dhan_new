<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice #<%= @booking.invoice_number || @booking.booking_number %></title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Arial, sans-serif;
        font-size: 12px;
        background: #f5f5f5;
        padding: 10px;
        color: #333;
      }

      .inv {
        max-width: 800px;
        margin: 0 auto;
        background: white;
        padding: 16px;
        border: 1px solid #ddd;
        position: relative;
      }

      /* ── PAID watermark ── */
      .paid-watermark {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%, -50%) rotate(-35deg);
        font-size: 90px; font-weight: 900;
        color: rgba(40,167,69,0.12);
        border: 10px solid rgba(40,167,69,0.12);
        border-radius: 10px; padding: 10px 25px;
        letter-spacing: 8px; pointer-events: none;
        z-index: 0; user-select: none; white-space: nowrap;
      }

      /* ── Type label ── */
      .inv-type-row { margin-bottom: 10px; }
      .inv-type { font-weight: bold; font-size: 13px; color: #333; }
      .inv-type-badge {
        font-size: 9px; color: #666; border: 1px solid #999;
        padding: 2px 6px; border-radius: 4px; margin-left: 8px;
        background: #f9f9f9; white-space: nowrap;
      }

      /* ── Header: logo + company info ── */
      .inv-header { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
      .inv-logo { width: 90px; height: 90px; border-radius: 50%; border: 3px solid #5a4ec9; flex-shrink: 0; object-fit: cover; }
      .inv-company-name { color: #5a4ec9; font-size: 20px; font-weight: bold; margin-bottom: 4px; }
      .inv-company-info { font-size: 10px; color: #333; line-height: 1.5; }

      /* ── Colour bars ── */
      .inv-bar { height: 6px; background: #5a4ec9; margin: 10px 0; }
      .inv-divider { height: 2px; background: #5a4ec9; margin: 10px 0; border-radius: 2px; }

      /* ── Invoice meta (Invoice No / Date / Due) ── */
      .inv-meta { display: flex; background: #e7e7e7; border-radius: 5px; overflow: hidden; margin: 10px 0; }
      .inv-meta-cell {
        flex: 1; padding: 8px 10px; font-size: 11px; font-weight: bold;
        border-right: 1px solid #ccc; text-align: center;
      }
      .inv-meta-cell:last-child { border-right: none; }
      .inv-meta-cell span { font-weight: normal; display: block; }

      /* ── Bill To / Ship To ── */
      .inv-addresses { display: flex; gap: 16px; margin: 10px 0; }
      .inv-addr { flex: 1; }
      .inv-addr-title { font-size: 11px; font-weight: bold; color: #5a4ec9; margin-bottom: 4px; }
      .inv-addr-name { font-size: 12px; font-weight: bold; margin-bottom: 3px; }
      .inv-addr-text { font-size: 10px; color: #555; line-height: 1.4; }

      /* ── Items table ── */
      .items-table { width: 100%; border-collapse: collapse; margin: 10px 0; }
      .items-table thead { border-top: 3px solid #5a4ec9; border-bottom: 3px solid #5a4ec9; background: #f8f9fa; }
      .items-table th { padding: 6px 4px; font-size: 11px; font-weight: bold; color: #333; text-align: left; }
      .items-table th.r { text-align: right; }
      .items-table th.c { text-align: center; }
      .items-table td { padding: 5px 4px; font-size: 11px; vertical-align: top; border-bottom: 1px solid #eee; }
      .items-table td.r { text-align: right; font-weight: bold; }
      .items-table td.c { text-align: center; }
      .items-table tbody tr:nth-child(even) { background: #f8f9fa; }
      .tax-rate { font-size: 9px; color: #888; }

      /* ── Subtotal bar ── */
      .inv-subtotal {
        display: flex; justify-content: space-between; align-items: center;
        border-top: 3px solid #5a4ec9; border-bottom: 3px solid #5a4ec9;
        background: #f8f9fa; padding: 8px 10px;
        font-weight: bold; font-size: 13px; margin: 10px 0;
      }

      /* ── Bank + Tax details ── */
      .inv-details { display: flex; gap: 16px; margin: 10px 0; }
      .inv-bank { flex: 1; min-width: 0; }
      .inv-tax { flex: 1; min-width: 0; border-left: 1px solid #ddd; padding-left: 14px; }

      .inv-section-title {
        font-size: 12px; font-weight: bold; color: #5a4ec9;
        border-bottom: 2px solid #5a4ec9; padding-bottom: 2px; margin-bottom: 6px;
      }

      .bank-table { width: 100%; border-collapse: collapse; font-size: 10px; background: #f9f9f9; border-radius: 5px; overflow: hidden; margin-bottom: 8px; }
      .bank-table td { padding: 4px 6px; border-bottom: 1px solid #eee; }
      .bank-table td:first-child { font-weight: bold; background: #f0f0f0; width: 38%; }

      .qr-row { display: flex; align-items: center; gap: 10px; background: #f9f9f9; padding: 6px; border-radius: 5px; }
      .qr-img { width: 65px; height: 65px; border: 2px solid #5a4ec9; border-radius: 6px; flex-shrink: 0; }
      .upi-id { font-size: 9px; color: #666; margin-bottom: 4px; }
      .upi-icons span {
        display: inline-block; margin: 2px 3px 2px 0; padding: 2px 5px;
        background: white; border: 1px solid #ddd; border-radius: 3px;
        font-size: 8px; font-weight: bold;
      }
      .phonepe { color: #5f2d91; } .gpay { color: #4285f4; }
      .paytm  { color: #00baf2; } .upi   { color: #ff6600; }

      /* ── Tax summary box ── */
      .tax-box { background: #f9f9f9; padding: 10px; border-radius: 5px; border: 1px solid #e0e0e0; font-size: 11px; }
      .tax-row { display: flex; justify-content: space-between; padding: 3px 0; border-bottom: 1px solid #eee; }
      .tax-row:last-child { border-bottom: none; }
      .tax-val { font-weight: bold; min-width: 70px; text-align: right; }
      .tax-total-block {
        background: #f0f0f0; padding: 7px; border-radius: 5px;
        border-top: 2px solid #5a4ec9; margin-top: 7px;
      }
      .tax-total-block .tax-row { border-bottom: 1px solid #ddd; }
      .tax-total-block .tax-row:last-child { border-bottom: none; }

      .amount-words { background: #f0f0f0; padding: 7px; border-radius: 5px; margin-top: 8px; }
      .amount-words strong { display: block; font-size: 11px; color: #5a4ec9; margin-bottom: 3px; }
      .amount-words p { font-size: 10px; font-weight: bold; }

      /* ── Terms + Signature ── */
      .inv-footer { display: flex; gap: 16px; margin-top: 14px; }
      .inv-terms { flex: 2; }
      .inv-terms-title { font-size: 12px; font-weight: bold; color: #5a4ec9; margin-bottom: 5px; }
      .inv-terms ol { font-size: 9px; padding-left: 14px; line-height: 1.4; }
      .inv-sig { flex: 1; text-align: center; }
      .sig-box { height: 50px; border: 2px solid #5a4ec9; border-radius: 5px; background: #f8f9fa; margin-bottom: 5px; }
      .sig-label { font-size: 9px; font-weight: bold; color: #333; }
      .sig-name { font-size: 10px; color: #5a4ec9; font-weight: bold; margin-top: 2px; }

      /* ══════════════════════════════════════
         MOBILE  (≤ 520px)
      ══════════════════════════════════════ */
      @media (max-width: 520px) {
        body { padding: 0; font-size: 11px; }
        .inv  { padding: 10px; border: none; border-radius: 0; }

        /* Watermark smaller */
        .paid-watermark { font-size: 42px; border-width: 6px; letter-spacing: 4px; }

        /* Header: logo stays left, company text wraps */
        .inv-logo { width: 60px; height: 60px; }
        .inv-company-name { font-size: 15px; }
        .inv-company-info { font-size: 9px; }

        /* Meta: 2 per row, last one full width */
        .inv-meta { flex-wrap: wrap; }
        .inv-meta-cell { flex: 0 0 50%; text-align: left; font-size: 10px; padding: 5px 8px; border-bottom: 1px solid #ccc; }
        .inv-meta-cell:last-child { flex: 0 0 100%; border-right: none; border-bottom: none; }

        /* Addresses: stack */
        .inv-addresses { flex-direction: column; gap: 8px; }

        /* Items: hide HSN + TAX columns */
        .col-hsn, .col-tax { display: none !important; }
        .items-table th, .items-table td { padding: 4px 3px; font-size: 9.5px; }

        /* Details: stack bank then tax */
        .inv-details { flex-direction: column; gap: 0; }
        .inv-tax { border-left: none; padding-left: 0; border-top: 1px solid #ddd; padding-top: 10px; margin-top: 10px; }

        /* QR row stays horizontal – fine on mobile */
        .qr-img { width: 55px; height: 55px; }

        /* Footer: stack */
        .inv-footer { flex-direction: column; gap: 10px; }
        .inv-sig { text-align: left; }
        .sig-box { width: 100px; }
      }

      @media print {
        body { padding: 0; background: white; }
        .inv { border: none; padding: 12px; }
        .paid-watermark { color: rgba(40,167,69,0.10); border-color: rgba(40,167,69,0.10); }
      }
    </style>
  </head>
  <body>
    <%
      has_gst = @booking.booking_items&.any? { |item| item.product&.gst_enabled }

      subtotal_amount = 0
      taxable_amount  = 0
      total_cgst = 0
      total_sgst = 0
      total_igst = 0

      (@booking.booking_items || []).each do |item|
        base_amount = item.quantity * (item.price || 0)

        if item.product&.gst_enabled
          taxable_amount += base_amount

          if item.product.cgst_percentage.present? && item.product.sgst_percentage.present?
            cgst_rate      = item.product.cgst_percentage
            sgst_rate      = item.product.sgst_percentage
            igst_rate      = item.product.igst_percentage || 0
            total_gst_rate = cgst_rate + sgst_rate + igst_rate
          elsif item.product.gst_percentage.present?
            total_gst_rate = item.product.gst_percentage || 0
            cgst_rate      = total_gst_rate / 2.0
            sgst_rate      = total_gst_rate / 2.0
            igst_rate      = 0
          else
            cgst_rate = sgst_rate = igst_rate = total_gst_rate = 0
          end

          total_item_tax = (base_amount * total_gst_rate / 100)

          if total_gst_rate > 0
            cgst_amount = (total_item_tax * cgst_rate / total_gst_rate).round(2)
            sgst_amount = (total_item_tax * sgst_rate / total_gst_rate).round(2)
            igst_amount = (total_item_tax * igst_rate / total_gst_rate).round(2)

            calculated_sum        = cgst_amount + sgst_amount + igst_amount
            total_item_tax_rounded = total_item_tax.round(2)

            if calculated_sum != total_item_tax_rounded
              if cgst_amount >= sgst_amount && cgst_amount >= igst_amount
                cgst_amount = total_item_tax_rounded - sgst_amount - igst_amount
              elsif sgst_amount >= igst_amount
                sgst_amount = total_item_tax_rounded - cgst_amount - igst_amount
              else
                igst_amount = total_item_tax_rounded - cgst_amount - sgst_amount
              end
            end
          else
            cgst_amount = sgst_amount = igst_amount = 0
          end

          total_cgst += cgst_amount
          total_sgst += sgst_amount
          total_igst += igst_amount

          subtotal_amount += base_amount + cgst_amount + sgst_amount + igst_amount
        else
          subtotal_amount += base_amount
        end
      end

      total_tax       = total_cgst + total_sgst + total_igst
      final_total     = subtotal_amount
      business_settings = @business
    %>

    <div class="inv">
      <% if @booking.payment_status_paid? %>
        <div class="paid-watermark">PAID</div>
      <% end %>

      <!-- Type label -->
      <div class="inv-type-row">
        <span class="inv-type"><%= has_gst ? 'TAX INVOICE' : 'BILL OF SUPPLY' %></span>
        <span class="inv-type-badge">ORIGINAL FOR RECIPIENT</span>
      </div>

      <!-- Header: logo + company -->
      <div class="inv-header">
        <img class="inv-logo" src="/logo.jpeg" alt="Logo" />
        <div>
          <div class="inv-company-name"><%= business_settings&.business_name || 'Dhanvantari Naturals' %></div>
          <div class="inv-company-info">
            <%= business_settings&.address || '#827 4th main 9th Block 2nd Stage Near Hanumagiri temple Nagarbhavi, Bangalore, Karnataka, 560072' %><br/>
            <strong>Mobile:</strong> <%= business_settings&.mobile || '9972808044' %> &nbsp;
            <strong>GSTIN:</strong> <%= business_settings&.gstin || '29AOIPT8113K1ZC' %><br/>
            <strong>PAN:</strong> <%= business_settings&.pan_number || 'AOIPT8113K' %> &nbsp;
            <strong>Email:</strong> <%= business_settings&.email || 'Dhanvantarinaturalsfarm@gmail.com' %>
          </div>
        </div>
      </div>

      <div class="inv-bar"></div>

      <!-- Invoice meta -->
      <div class="inv-meta">
        <div class="inv-meta-cell">Invoice No.<span><%= @booking.invoice_number || @booking.booking_number %></span></div>
        <div class="inv-meta-cell">Invoice Date<span><%= Date.current.strftime('%d/%m/%Y') %></span></div>
        <div class="inv-meta-cell">Due Date<span><%= (Date.current + 30.days).strftime('%d/%m/%Y') %></span></div>
      </div>

      <div class="inv-divider"></div>

      <!-- Bill To / Ship To -->
      <div class="inv-addresses">
        <div class="inv-addr">
          <div class="inv-addr-title">BILL TO</div>
          <div class="inv-addr-name"><%= @booking.customer_name || @booking.customer&.display_name || 'Customer' %></div>
          <div class="inv-addr-text"><%= @booking.delivery_address || @booking.customer&.address %></div>
          <% ph = @booking.customer_phone || @booking.customer&.mobile %>
          <% if ph.present? %><div class="inv-addr-text">Mobile: <%= ph %></div><% end %>
        </div>
        <div class="inv-addr">
          <div class="inv-addr-title">SHIP TO</div>
          <div class="inv-addr-name"><%= @booking.customer_name || @booking.customer&.display_name || 'Customer' %></div>
          <div class="inv-addr-text"><%= @booking.delivery_address || @booking.customer&.address %></div>
        </div>
      </div>

      <!-- Items table (col-hsn and col-tax hidden on mobile) -->
      <table class="items-table">
        <thead>
          <tr>
            <th>ITEMS</th>
            <th class="c col-hsn">HSN</th>
            <th class="c">QTY.</th>
            <th class="r">RATE</th>
            <th class="r col-tax">TAX</th>
            <th class="r">AMOUNT</th>
          </tr>
        </thead>
        <tbody>
          <% (@booking.booking_items || []).each do |item|
               unit_price  = item.price || 0
               base_amount = item.quantity * unit_price
               if item.product&.gst_enabled
                 if item.product.cgst_percentage.present? || item.product.sgst_percentage.present?
                   row_gst_rate = (item.product.cgst_percentage || 0) + (item.product.sgst_percentage || 0) + (item.product.igst_percentage || 0)
                 else
                   row_gst_rate = item.product.gst_percentage || 0
                 end
                 row_tax    = (base_amount * row_gst_rate / 100).round(2)
                 row_total  = base_amount + row_tax
               else
                 row_gst_rate = 0
                 row_tax      = 0
                 row_total    = base_amount
               end
          %>
          <tr>
            <td><%= item.product&.name || 'Product' %></td>
            <td class="c col-hsn"><%= item.product&.hsn_code || '-' %></td>
            <td class="c"><%= item.quantity.to_s.sub(/\.0$/,'') %> <%= item.product&.unit_type || 'Pcs' %></td>
            <td class="r">₹<%= number_with_delimiter(sprintf('%.2f', unit_price), delimiter: ',') %></td>
            <td class="r col-tax">
              ₹<%= number_with_delimiter(row_tax, delimiter: ',') %><br/>
              <span class="tax-rate">(<%= row_gst_rate.to_i == row_gst_rate ? row_gst_rate.to_i : row_gst_rate %>%)</span>
            </td>
            <td class="r">₹<%= number_with_delimiter(sprintf('%.2f', row_total), delimiter: ',') %></td>
          </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Subtotal -->
      <div class="inv-subtotal">
        <span>SUBTOTAL</span>
        <span>₹ <%= number_with_delimiter(subtotal_amount.round(2), delimiter: ',') %></span>
      </div>

      <!-- Bank details + Tax summary -->
      <div class="inv-details">
        <!-- Bank details -->
        <div class="inv-bank">
          <div class="inv-section-title">BANK DETAILS</div>
          <table class="bank-table">
            <tr><td>Name</td><td><%= business_settings&.account_holder_name || 'Dhanvantari Naturals' %></td></tr>
            <tr><td>IFSC</td><td><%= business_settings&.ifsc_code || 'CNRB0003194' %></td></tr>
            <tr><td>Account</td><td><%= business_settings&.account_number || '3194201000718' %></td></tr>
            <tr><td>Bank</td><td><%= business_settings&.bank_name || 'Canara Bank' %></td></tr>
          </table>

          <div class="inv-section-title" style="margin-top:8px;">PAYMENT QR CODE</div>
          <div class="qr-row">
            <div>
              <div class="upi-id">UPI: <%= business_settings&.upi_id || '9972808044@ybl' %></div>
              <div class="upi-icons">
                <span class="phonepe">PhonePe</span>
                <span class="gpay">GPay</span>
                <span class="paytm">Paytm</span>
                <span class="upi">UPI</span>
              </div>
            </div>
            <img class="qr-img"
                 src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=upi://pay?pa=<%= business_settings&.upi_id || '9972808044@ybl' %>&pn=<%= CGI.escape(business_settings&.business_name || 'Dhanvantari Naturals') %>"
                 alt="QR Code" />
          </div>
        </div>

        <!-- Tax summary -->
        <div class="inv-tax">
          <div class="inv-section-title">TAX SUMMARY</div>
          <div class="tax-box">
            <div class="tax-row">
              <span>TAXABLE AMOUNT</span>
              <span class="tax-val">₹ <%= number_with_delimiter(taxable_amount.round(2), delimiter: ',') %></span>
            </div>

            <%
              cgst_groups = {}
              sgst_groups = {}
              (@booking.booking_items || []).each do |item|
                if item.product&.gst_enabled
                  bamt = item.quantity * (item.price || 0)
                  if item.product.cgst_percentage.present? && item.product.sgst_percentage.present?
                    cr = item.product.cgst_percentage
                    sr = item.product.sgst_percentage
                  elsif item.product.gst_percentage.present?
                    cr = item.product.gst_percentage / 2.0
                    sr = cr
                  else
                    cr = sr = 0
                  end
                  if cr > 0
                    cgst_groups[cr] = (cgst_groups[cr] || 0) + (bamt * cr / 100).round(2)
                  end
                  if sr > 0
                    sgst_groups[sr] = (sgst_groups[sr] || 0) + (bamt * sr / 100).round(2)
                  end
                end
              end
              all_rates = (cgst_groups.keys + sgst_groups.keys).uniq.sort
              all_rates.each do |rate|
            %>
              <% if cgst_groups[rate].to_f > 0 %>
                <div class="tax-row">
                  <span>CGST @<%= rate.to_i == rate ? rate.to_i : rate %>%</span>
                  <span class="tax-val">₹ <%= number_with_delimiter(cgst_groups[rate].round(2), delimiter: ',') %></span>
                </div>
              <% end %>
              <% if sgst_groups[rate].to_f > 0 %>
                <div class="tax-row">
                  <span>SGST @<%= rate.to_i == rate ? rate.to_i : rate %>%</span>
                  <span class="tax-val">₹ <%= number_with_delimiter(sgst_groups[rate].round(2), delimiter: ',') %></span>
                </div>
              <% end %>
            <% end %>
            <% if total_igst > 0 %>
              <% igst_rate = (@booking.booking_items || []).select { |i| i.product&.gst_enabled }.sum { |i| i.product.igst_percentage || 0 }.to_f / [(@booking.booking_items || []).select { |i| i.product&.gst_enabled }.count, 1].max rescue 0 %>
              <div class="tax-row">
                <span>IGST @<%= igst_rate %>%</span>
                <span class="tax-val">₹ <%= number_with_delimiter(total_igst.round(2), delimiter: ',') %></span>
              </div>
            <% end %>

            <div class="tax-total-block">
              <div class="tax-row" style="font-weight:bold;">
                <span>TOTAL AMOUNT</span>
                <span class="tax-val">₹ <%= number_with_delimiter(subtotal_amount.round(2), delimiter: ',') %></span>
              </div>
              <div class="tax-row" style="font-size:10px;">
                <span>Received Amount</span>
                <span class="tax-val">₹ <%= @booking.payment_status_paid? ? number_with_delimiter(final_total.round(2), delimiter: ',') : '0' %></span>
              </div>
            </div>

            <%
              ones  = ["","One","Two","Three","Four","Five","Six","Seven","Eight","Nine"]
              teens = ["Ten","Eleven","Twelve","Thirteen","Fourteen","Fifteen","Sixteen","Seventeen","Eighteen","Nineteen"]
              tens  = ["","","Twenty","Thirty","Forty","Fifty","Sixty","Seventy","Eighty","Ninety"]
              def conv_h(n, ones, teens, tens)
                r=""
                if n>=100; r+=ones[n/100]+" Hundred "; n%=100; end
                if n>=20;  r+=tens[n/10]+" "; n%=10
                elsif n>=10; r+=teens[n-10]+" "; n=0; end
                r+=ones[n]+" " if n>0
                r.strip
              end
              amt=subtotal_amount.to_i; words=""
              if amt>=10000000; words+=conv_h(amt/10000000,ones,teens,tens)+" Crore "; amt%=10000000; end
              if amt>=100000;   words+=conv_h(amt/100000,ones,teens,tens)+" Lakh "; amt%=100000; end
              if amt>=1000;     words+=conv_h(amt/1000,ones,teens,tens)+" Thousand "; amt%=1000; end
              words+=conv_h(amt,ones,teens,tens) if amt>0
              words=words.strip; words="Zero" if words.empty?
            %>
            <div class="amount-words">
              <strong>Total Amount (in words)</strong>
              <p><%= words %> Rupees Only</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Terms + Signature -->
      <div class="inv-footer">
        <div class="inv-terms">
          <div class="inv-terms-title">TERMS AND CONDITIONS</div>
          <% if business_settings&.terms_and_conditions.present? %>
            <% fmt = business_settings.formatted_terms_and_conditions %>
            <% if fmt.any? %>
              <ol><% fmt.each do |t| %><li><%= t %></li><% end %></ol>
            <% else %>
              <div style="font-size:9px;padding-left:14px;"><%= simple_format(business_settings.terms_and_conditions) %></div>
            <% end %>
          <% else %>
            <ol>
